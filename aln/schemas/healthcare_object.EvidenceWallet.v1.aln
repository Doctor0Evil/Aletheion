-- ============================================================================
-- SCHEMA: healthcare_object.EvidenceWallet.v1
-- PURPOSE: Personal evidence wallet for augmented citizens
-- COMPLIANCE: GDPR, HIPAA, EU AI Act 2024, Neurorights Charter v1
-- OWNER: did:aln:bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
-- ============================================================================

schema healthcare_object.EvidenceWallet.v1
  description "Personal evidence wallet for augmented citizens showing which \
               eco and health improvements they benefited from, with links \
               to open ROW records. Used for care access, not finance."

  fields
    -- Wallet identifier (DID-anchored)
    wallet_id             string   -- required, unique, auto-generated

    -- Owner's Decentralized Identifier
    owner_did             string   -- required, e.g., "did:aln:bostrom18..."

    -- Linked BCI augmentation (FK -> healthcare_object.BCIClinicalAugmentation.v1.device_id)
    linked_bci_device_id  string   -- optional, links to organic BCI if present

    -- Evidence records (array of ROW references)
    evidence_records      string[] -- required, array of ROW entry hashes

    -- Health improvements (structured data)
    health_improvements   json     -- required, schema: {metric, delta, row_ref, timestamp}

    -- Eco improvements (structured data)
    eco_improvements      json     -- required, schema: {metric, delta, row_ref, timestamp}

    -- Care access permissions (array of authorized provider DIDs)
    care_access_providers string[] -- optional, array of provider DIDs

    -- Consciousness preservation data (encrypted, for event-of-Death continuity)
    consciousness_preservation_data bytes -- optional, encrypted, requires explicit consent

    -- Wallet status
    wallet_status         string   -- enum: "active", "suspended", "archived", "preserved"

    -- Creation timestamp (ISO 8601, UTC)
    created_at            timestamp -- auto-generated

    -- Last update timestamp (ISO 8601, UTC)
    updated_at            timestamp -- auto-updated

    -- Evidence completeness score (0.0 - 1.0)
    evidence_completeness_score float -- auto-calculated, required >= 0.86 for active status

  indexes
    by_owner_did (owner_did)
    by_wallet_status (wallet_status)
    by_bci_device (linked_bci_device_id)

  invariants
    -- Invariant 1: Evidence completeness must meet threshold
    invariant evidence_completeness_score >= 0.86
      error_message "Evidence wallet completeness score must be >= 0.86 for active status"

    -- Invariant 2: Owner DID must be valid
    invariant owner_did STARTS_WITH "did:aln:"
      error_message "Owner DID must be a valid ALN DID"

    -- Invariant 3: Consciousness preservation requires explicit consent
    invariant consciousness_preservation_data IS_NULL OR consent_profile IS_NOT_NULL
      error_message "Consciousness preservation requires explicit consent profile"

  version "1.0.0"
  owner_did "did:aln:bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7"
end
