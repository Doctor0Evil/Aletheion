// ============================================================================
// SECTION 1: RISK COORDINATE DEFINITIONS (r_x)
// Normalized 0.0-1.0 scale for all biodegradable and cyboquatic materials
// ============================================================================

riskcoord,r_degrade,type,float32,min,0.0,max,1.0,unit,rate_per_day
riskcoord,r_degrade,desc,Degradation rate risk (0=stable polymer, 1=volatile organic)
