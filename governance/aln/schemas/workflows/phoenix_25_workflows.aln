# Aletheion Phoenix 25-Workflow Canonical Schema [file:5][file:2]
# This ALN file encodes:
# - A reusable workflow pattern grammar (INGEST → STATE → OPTIMIZE → GOVERN → ACTUATE → TRUST → SURFACE).
# - Domain-specific workflow instances for the first 25 Phoenix automations.
# - Binding to Birth-Signs, Rights grammars, BioticTreaties, and SMART-Chain ids. [file:5][file:2]

schema PhoenixWorkflowSchema v1 {
    meta {
        jurisdiction = "US-AZ-PHX";
        project      = "Aletheion-Phoenix";
        source_docs  = [
            "Aletheion Phoenix GOD-City: 25 Workflow Blueprint",
            "Governed Urban Workflow Architecture",
            "ERM Architecture: Phoenix Smart City Blueprint"
        ];
    }

    # ---------------------------
    # Core types and enumerations
    # ---------------------------

    enum Layer {
        EDGE_SENSING,
        STATE_MODEL,
        BLOCKCHAIN_TRUST,
        OPTIMIZATION_ENGINE,
        CITIZEN_INTERFACE
    }

    enum WorkflowDomain {
        WATER,
        THERMAL,
        SEWER,
        MATERIALS,
        ENERGY,
        MOBILITY,
        GOVERNANCE,
        NEUROBIOME,
        SYNTHEXIS,
        LEXETHOS,
        CITIZEN
    }

    enum StageKind {
        INGEST,
        STATE_UPDATE,
        OPTIMIZE,
        TREATY_CHECK,
        ACTUATE,
        TRUST_APPEND,
        CITIZEN_SURFACE
    }

    enum RiskEnvelope {
        FEAR,
        PAIN,
        SANITY
    }

    enum RightsGrammar {
        RightToShade,
        RightToSafeMovement,
        FPIC,
        BioticTreaty,
        LexEthos,
        CryptoSomatic
    }

    enum EnforcementMode {
        HARD,
        HIGH_PENALTY
    }

    enum PqMode {
        NONE,
        HYBRID,
        PQ_STRICT
    }

    type WorkflowId = string
        pattern = "^WF-[0-9]{3}-[A-Z0-9_]+$";

    type SmartChainId = string
        pattern = "^SMART_[0-9]{2}_[A-Z0-9_]+$";

    type BirthSignRef = string
        pattern = "^BS-[A-Z0-9:_-]+$";

    type RepoPath = string;

    # -----------------------------
    # Canonical workflow pattern
    # -----------------------------

    record WorkflowStage {
        id: string;
        kind: StageKind;
        layer: Layer;

        impl_path: RepoPath;

        requires_birth_sign: bool;
        birth_sign_domains: [WorkflowDomain];

        required_rights: [RightsGrammar];
        required_risk_envelopes: [RiskEnvelope];

        enforcement_mode: EnforcementMode;

        smart_chain: SmartChainId?;
        pq_mode: PqMode;

        description: string;
    }

    record Workflow {
        id: WorkflowId;
        name: string;
        domains: [WorkflowDomain];
        layers: [Layer];

        stages: [WorkflowStage];

        # Birth-Sign scope and requirements. [file:2]
        birth_sign_required: bool;
        birth_sign_scopes: [BirthSignRef];

        # Rights grammars and treaties this workflow must honor. [file:2][file:5]
        rights_grammars: [RightsGrammar];
        biotic_treaties_required: bool;

        # PQ cryptography mode for this workflow overall. [file:4]
        pq_mode: PqMode;

        # Human-readable explanation for operators and citizens.
        summary: string;
    }

    record WorkflowSet {
        workflows: [Workflow];
    }
}

use PhoenixWorkflowSchema::*;

# -------------------------------------------
# Canonical pattern: all workflows must have:
# INGEST → STATE_UPDATE → OPTIMIZE → TREATY_CHECK → ACTUATE → TRUST_APPEND
# Optional CITIZEN_SURFACE stages for interface-facing flows. [file:5][file:2]
# -------------------------------------------

const PATTERN_BASE_STAGES = [
    StageKind::INGEST,
    StageKind::STATE_UPDATE,
    StageKind::OPTIMIZE,
    StageKind::TREATY_CHECK,
    StageKind::ACTUATE,
    StageKind::TRUST_APPEND
];

