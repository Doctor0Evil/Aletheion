// ============================================================================
// FILE: aletheion/governance/lexethos/ALE-LEX-RIGHTS-ATOM-002.aln
// PURPOSE: Refined RightsAtom definitions for DowntownCentral Phoenix with
//          shade, movement, noise, hydration rights compiled into MicroTreaties
//          consumed by Synthexis, Thermaphora, Somaplex engines
// LANGUAGE: ALN (Aletheion Logic Notation) - Version 002
// DESTINATION: Aletheion Repository - Governance LexEthos Subsystem
// COMPLIANCE: Zero-contamination IFC, NeurorightsEnvelope, FPIC metadata,
//             EU AI Act Article 5, Neuro-Rights Framework 2025, WCAG 2.2 AAA
// AUTHORITY: Single semantic source - All engines read this schema, none bypass
// RELATED: ALE-LEX-MICROTREATY-COMPILER-CORE-002.rs, ALE-CIT-CONSENT-STATE-002.aln
// ============================================================================

@version "002"
@domain "aletheion.governance.lexethos"
@policy_type "rights_atom_core"
@effective_date "2026-03-08T00:00:00Z"
@jurisdiction "Phoenix, Arizona, USA"
@indigenous_territory "Akimel O'odham and Piipaash ancestral lands"

// ============================================================================
// SECTION 1: RIGHTS ATOM SCHEMA DEFINITIONS
// ============================================================================

@rights_atom_schema {
    name: "Aletheion_RightsAtom"
    version: "002"
    
    @field atom_id {
        type: "string"
        pattern: "^RA-[0-9]{6}-[A-Z]{4}$"
        required: true
        immutable: true
        description: "Unique rights atom identifier"
    }
    
    @field right_category {
        type: "enum"
        allowed_values: [shade, movement, noise, hydration, thermal, biotic, somatic, neurobiome, treaty, waste]
        required: true
        immutable: true
        description: "Rights category classification"
    }
    
    @field right_name {
        type: "string"
        pattern: "^[A-Za-z_]+$"
        required: true
        immutable: true
        description: "Human-readable right name"
    }
    
    @field right_description {
        type: "string"
        max_length: 500
        required: true
        mutable: false
        description: "Detailed rights description"
    }
    
    @field legal_basis {
        type: "array"
        item_type: "string"
        required: true
        mutable: false
        description: "Legal foundations (ADA, EU AI Act, Phoenix Municipal Code)"
    }
    
    @field enforcement_level {
        type: "enum"
        allowed_values: [fundamental, protected, conditional, advisory]
        required: true
        mutable: false
        description: "Rights enforcement classification"
    }
    
    @field violation_severity {
        type: "enum"
        allowed_values: [critical, high, medium, low]
        required: true
        mutable: false
        description: "Violation severity classification"
    }
    
    @field remediation_required {
        type: "boolean"
        required: true
        mutable: false
        description: "Automatic remediation trigger"
    }
    
    @field stake_multisig_override {
        type: "boolean"
        required: true
        mutable: false
        description: "Stake multisig can override"
    }
    
    @field fpic_required {
        type: "boolean"
        required: true
        mutable: false
        description: "FPIC verification required"
    }
    
    @field neurorights_envelope {
        type: "boolean"
        required: true
        mutable: false
        description: "Neurorights protection applies"
    }
    
    @field evp_record_required {
        type: "boolean"
        required: true
        mutable: false
        description: "EvolutionProposalRecord required for changes"
    }
    
    @invariant rights_invariant_001 {
        description: "Fundamental rights cannot be overridden without stake multisig"
        condition: enforcement_level == fundamental => stake_multisig_override == true
        enforcement: hard_block
    }
    
    @invariant rights_invariant_002 {
        description: "Critical violations require automatic remediation"
        condition: violation_severity == critical => remediation_required == true
        enforcement: hard_block
    }
    
    @invariant rights_invariant_003 {
        description: "Neurorights envelope required for neurobiome category"
        condition: right_category == neurobiome => neurorights_envelope == true
        enforcement: hard_block
    }
    
    @invariant rights_invariant_004 {
        description: "FPIC required for all fundamental and protected rights"
        condition: enforcement_level in [fundamental, protected] => fpic_required == true
        enforcement: hard_block
    }
}

// ============================================================================
// SECTION 2: SHADE RIGHTS ATOMS (Phoenix Extreme Heat Context)
// ============================================================================

@rights_atom shade_access_fundamental {
    atom_id: "RA-000001-SHAD"
    right_category: shade
    right_name: "Shade_Access_Right"
    right_description: "Every citizen has the right to access shaded pedestrian corridors during extreme heat conditions (ambient temp >= 35°C)"
    legal_basis: ["Phoenix Heat Relief Network Ordinance 2025", "ADA Accessibility Guidelines", "Thermal Human Rights Framework 2025"]
    enforcement_level: fundamental
    violation_severity: critical
    remediation_required: true
    stake_multisig_override: true
    fpic_required: true
    neurorights_envelope: false
    evp_record_required: true
    
    @threshold {
        ambient_temp_trigger_c: 35.0
        shade_coverage_min_pct: 50.0
        cooling_station_max_distance_m: 400.0
        citation: "Phoenix HeatReady program 2025"
    }
    
    @enforcement {
        automatic_action: "activate_shade_structures"
        notification_targets: ["city_planning", "heat_relief_network", "citizen_alert_system"]
        timeline_hours: 2
        citation: "Phoenix emergency heat protocol"
    }
}

@rights_atom shade_tree_canopy {
    atom_id: "RA-000002-TREE"
    right_category: shade
    right_name: "Tree_Canopy_Right"
    right_description: "Every neighborhood has the right to minimum 30% tree canopy coverage for urban heat island mitigation"
    legal_basis: ["Phoenix Urban Forestry Master Plan 2025", "Sonoran Desert Conservation Ordinance"]
    enforcement_level: protected
    violation_severity: high
    remediation_required: true
    stake_multisig_override: true
    fpic_required: false
    neurorights_envelope: false
    evp_record_required: true
    
    @threshold {
        canopy_coverage_min_pct: 30.0
        native_species_ratio_min: 0.8
        tree_spacing_max_m: 15.0
        citation: "Phoenix shade tree canopy target 2025"
    }
    
    @enforcement {
        automatic_action: "initiate_tree_planting_program"
        notification_targets: ["urban_forestry", "neighborhood_association"]
        timeline_days: 90
        citation: "Phoenix Urban Forestry implementation"
    }
}

@rights_atom cool_pavement_access {
    atom_id: "RA-000003-COOL"
    right_category: shade
    right_name: "Cool_Pavement_Right"
    right_description: "Every pedestrian corridor has the right to cool pavement surfaces (10.5-12°F reduction) in high-traffic zones"
    legal_basis: ["Phoenix Cool Pavement Program 2025", "Urban Heat Mitigation Standards"]
    enforcement_level: protected
    violation_severity: medium
    remediation_required: true
    stake_multisig_override: false
    fpic_required: false
    neurorights_envelope: false
    evp_record_required: true
    
    @threshold {
        surface_temp_reduction_min_f: 10.5
        albedo_coefficient_min: 0.25
        high_traffic_threshold_ped_per_day: 1000
        citation: "140+ miles cool pavement deployed Phoenix 2025"
    }
    
    @enforcement {
        automatic_action: "schedule_cool_pavement_application"
        notification_targets: ["public_works", "transportation_department"]
        timeline_days: 180
        citation: "Phoenix Public Works cool pavement schedule"
    }
}

