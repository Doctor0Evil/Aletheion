// Aletheion LexEthos Rights Grammar Core
// File: ALE-LEX-RIGHTS-GRAMMAR-001.aln
// Path: aletheion/governance/lexethos/ALE-LEX-RIGHTS-GRAMMAR-001.aln

namespace aletheion.governance.lexethos.grammar.v1

// ---- Primitive enums ----

enum RightType {
  noise_quiet_hours,
  noise_peak_ceiling,
  shade_waiting_area,
  shade_transit_peak_heat,
  shade_crossing_refuge,
  water_access_basic,
  augmentation_boundary,
  data_privacy_local
}

enum MetricKind {
  dba_at_facade,
  dba_at_lot_line,
  lux_horizontal,
  lux_vertical,
  shade_fraction,
  shade_length_m,
  duration_minutes,
  distance_m
}

enum Comparator {
  lt,   // <
  lte,  // <=
  gt,   // >
  gte,  // >=
  eq,   // ==
}

enum EnforcementMode {
  hard_block,   // plan must be rejected or structurally changed
  derate,       // plan may be auto-modified (time/route/intensity)
  warn_only     // log and notify, no auto-change
}

enum CapitalTag {
  Water,
  Thermal,
  Waste,
  Biotic,
  Neurobiome,
  Somatic,
  Treaty
}

// ---- Core identifiers ----

type RightId = string
type TreatyId = string
type DistrictId = string        // aligns with SevenCapitalState districts
type CorridorId = string        // canal, shade corridor, riparian segment
type AssetType = string         // e.g. "construction_site", "bus_stop", "freight_link"
type Did = string               // W3C DID
type GoogolswarmTxHash = string // Googolswarm transaction anchor

// ---- Time and scope primitives ----

type LocalTime = string         // "HH:MM", 24h local
type LocalDate = string         // "YYYY-MM-DD"
type DayOfWeek = string         // "Mon"|"Tue"|...

record TimeScope {
  start_time: LocalTime,        // inclusive
  end_time:   LocalTime,        // exclusive
  days_of_week: [DayOfWeek],    // empty => all days
}

record SeasonalWindow {
  start_date: LocalDate,        // inclusive
  end_date:   LocalDate,        // inclusive
}

record Jurisdiction {
  districts:   [DistrictId],    // one or more districts
  corridors:   [CorridorId],    // optional linear identities
  asset_types: [AssetType],     // which asset classes this atom binds
}

// ---- Threshold and metric binding ----

record Threshold {
  metric:     MetricKind,
  comparator: Comparator,
  value:      float,
}

// ---- RightsAtom: minimal enforceable unit ----

record RightsAtom {
  right_id:       RightId,
  right_type:     RightType,
  subject_role:   string,        // "resident", "worker", "clinic_patient", "school_child"
  obligor_role:   string,        // "city_ops", "contractor", "fleet_operator", "building_owner"

  jurisdiction:   Jurisdiction,
  time_scope:     TimeScope,
  season:        ?SeasonalWindow,

  threshold:      Threshold,
  enforcement:    EnforcementMode,
  capital_links:  [CapitalTag],

  provenance_did_issuer:  Did,
  provenance_tx_anchor:   GoogolswarmTxHash,
  version:        string,        // e.g. "PHX-NOISE-SHADE-V1"
  created_at:     string,        // ISO-8601 timestamp
}

// ---- MicroTreaty schema shell (no logic here) ----

record MicroTreaty {
  treaty_id:      TreatyId,
  name:           string,
  description:    string,
  atoms:          [RightsAtom],

  valid_from:     LocalDate,
  valid_until:    LocalDate,

  jurisdictions:  [Jurisdiction],
  supersedes:     [TreatyId],
  authors:        [Did],
  reviewers:      [Did],
  version:        string,
}

// ---- Phoenix noise / shade mini-grammar presets ----
// These atoms are designed to be compiled by ALE-LEX-COMPILER-001.rs
// into executable MicroTreaties and attached to districts like
// "Downtown Cool Corridor" and heat-vulnerable neighborhoods.

