        max_total_mass_grams        = 5000.0
        monitoring_frequency_hours  = 24
        enforcement_mode            = HARD_BLOCK
        severity                    = CRITICAL
        biotic_treaty_refs          = ["ALE-BIOTIC-BAT-CANAL-CORRIDOR-001"]
        species_agent_refs          = [{ species_agent_id = "SPECIES-MYOTIS-VELIFER" }]
    }
}

