    alert_threshold_ppb     : Decimal
    shutdown_threshold_ppb  : Decimal
    sampling_frequency_hours : Int
    fpic_required           : Bool
    indigenous_water_rights_ref : Id?
    enforcement_mode        : EnforcementMode
    severity                : Severity
}

