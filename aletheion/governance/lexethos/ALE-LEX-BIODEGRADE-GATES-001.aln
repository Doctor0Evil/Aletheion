        severity                    = CRITICAL
    }
}

// =============================================================================
// 11. Decomposition Rate Limit Gates
// =============================================================================

record DecompositionRateLimitGate {
    gate_id                 : Id
    domain                  : Domain
    material_class          : BiodegradeMaterialClass
    max_r_micro_grams_per_day : Decimal
    max_r_tox_ppb           : Decimal
    temperature_correction_factor : Decimal
    ph_correction_factor    : Decimal
    monitoring_frequency_hours : Int
    enforcement_mode        : EnforcementMode
    severity                : Severity
}

