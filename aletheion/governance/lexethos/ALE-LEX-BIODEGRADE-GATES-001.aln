    timestamp_unix          : Int
    auditor_signature       : Id
    citizen_accessible      : Bool
    grievance_linked        : Bool
}

// =============================================================================
// 19. SMART Chain Policy Bindings
// =============================================================================

record SmartChainBiodegradePolicy {
    policy_id               : Id
    domain                  : Domain
    required_gates          : [BiodegradeGateType]
    hard_block_gate_types   : [BiodegradeGateType]
    min_ecosafety_score     : Decimal
    fpic_required_domains   : [Domain]
    ej_zone_enhanced_review : Bool
    biotic_treaty_required  : Bool
    audit_frequency_hours   : Int
    citizen_notification_required : Bool
    grievance_window_hours  : Int
    human_review_threshold  : Decimal
    enforcement_mode        : EnforcementMode
}

// Canonical: Water Domain Biodegrade Policy
record Example_SmartChainPolicy_Water {
    policy : SmartChainBiodegradePolicy = {
        policy_id                   = "ALE-POLICY-SMART-WATER-BIODEGRADE-001"
        domain                      = WATER
        required_gates              = [HABITAT_BUFFER, SEWER_OUTFALL_RESTRICTION, INDIGENOUS_TERRITORY_FPIC, EJ_ZONE_TOXICITY_CAP]
        hard_block_gate_types       = [HABITAT_BUFFER, SEWER_OUTFALL_RESTRICTION, INDIGENOUS_TERRITORY_FPIC]
        min_ecosafety_score         = 0.85
        fpic_required_domains       = [WATER, WASTE, SOIL]
        ej_zone_enhanced_review     = true
        biotic_treaty_required      = true
        audit_frequency_hours       = 24
        citizen_notification_required = true
        grievance_window_hours      = 72
        human_review_threshold      = 0.7
        enforcement_mode            = HARD_BLOCK
    }
}

// =============================================================================
// 20. Gate Evaluation Contract (Rust Binding Interface)
// =============================================================================

// This defines the boundary that Rust gate evaluation modules must honor.
// In Rust, each gate evaluator would expose a function equivalent to:
//
//   fn evaluate_gate(ctx: BiodegradeGateContext, gate: BiodegradeGate) -> BiodegradeGateResult;
//
// An orchestrator composes multiple gate results into an overall decision
// and ensures that any FAIL_HARD decisions block actuation before
// appending to Googolswarm provenance envelopes.

record BiodegradeGateEvaluatorContract {
    evaluator_id            : Id
    description             : string
    accepts_gate_types      : [BiodegradeGateType]
    accepts_domains         : [Domain]
    requires_birth_sign     : Bool
    requires_fpic           : Bool
    requires_ej_zones       : Bool
    requires_biotic_refs    : Bool
    output_schema_ref       : Id
    version                 : string
}

record BiodegradeGateEvaluatorRegistry {
    registry_id             : Id
    evaluators              : [BiodegradeGateEvaluatorContract]
    version                 : string
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
}

// End of Aletheion Governance Lexethos Biodegrade Gates
