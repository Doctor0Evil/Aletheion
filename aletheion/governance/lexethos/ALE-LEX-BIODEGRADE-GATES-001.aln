// Aletheion Governance Lexethos Biodegrade Gates
// File: ALE-LEX-BIODEGRADE-GATES-001.aln
// Domain: Governance / Lexethos / Biodegrade Treaty Enforcement
// Compliance: BioticTreaties, Indigenous FPIC, EJ Zones, SMART Chain

aln_version 1.0
namespace Aletheion.Governance.Lexethos.Biodegrade

import Aletheion.ERM.Ecosafety.Biodegrade
import Aletheion.TreatyOS

// =============================================================================
// 1. Biodegrade-Specific Treaty Gates
// =============================================================================

enum BiodegradeGateType {
    HABITAT_BUFFER
    SEWER_OUTFALL_RESTRICTION
    WETLAND_PROTECTION
    CANAL_CORRIDOR_LIMIT
    MAR_VAULT_WATER_QUALITY
    INDIGENOUS_TERRITORY_FPIC
    EJ_ZONE_TOXICITY_CAP
    BIOTIC_CORRIDOR_DARKNESS
    SEASONAL_BLACKOUT
    DECOMPOSITION_RATE_LIMIT
}

enum GateDecision {
    PASS
    FAIL_HARD
    FAIL_SOFT
    PASS_WITH_CONDITIONS
}

record BiodegradeGate {
    gate_id                 : Id
    gate_type               : BiodegradeGateType
    domain                  : Domain
    description             : string
    priority                : Int
    enforcement_mode        : EnforcementMode
    severity                : Severity
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
    geo_scope_refs          : [Id]
    material_class_restrictions : [BiodegradeMaterialClass]
    threshold_value         : Decimal?
    threshold_unit          : string?
    buffer_meters           : Decimal?
    fpic_required           : Bool
    audit_trail_required    : Bool
    citizen_notification    : Bool
    grievance_link_template : string
}

// =============================================================================
// 2. Habitat Buffer Gates
// =============================================================================

record HabitatBufferGate {
    gate_id                 : Id
    protected_habitat_id    : Id
    habitat_type            : string
    buffer_distance_meters  : Decimal
    prohibited_materials    : [BiodegradeMaterialClass]
    allowed_materials       : [BiodegradeMaterialClass]
    max_node_density_per_km2 : Decimal
    max_total_mass_grams    : Decimal
    monitoring_frequency_hours : Int
    enforcement_mode        : EnforcementMode
    severity                : Severity
    biotic_treaty_refs      : [Id]
    species_agent_refs      : [SpeciesAgentRef]
}

