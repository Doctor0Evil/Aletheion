// =============================================================================
// 10. Seasonal Blackout Gates
// =============================================================================

record SeasonalBlackoutGate {
    gate_id                 : Id
    zone_id                 : Id
    blackout_type           : string
    start_date              : IsoTimestamp
    end_date                : IsoTimestamp
    prohibited_actions      : [string]
    allowed_exceptions      : [string]
    notification_required   : Bool
    enforcement_mode        : EnforcementMode
    severity                : Severity
}

