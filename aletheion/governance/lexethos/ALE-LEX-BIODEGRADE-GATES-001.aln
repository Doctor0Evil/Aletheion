    }
}

// =============================================================================
// 12. Gate Evaluation Context
// =============================================================================

record BiodegradeGateContext {
    context_id              : Id
    workflow_id             : Id
    node_id                 : Id
    material_ref            : Id
    geo_tile_ref            : Id
    birth_sign_id           : Id
    timestamp_unix          : Int
    proposed_action         : string
    action_parameters       : [string]
    current_node_state      : BiodegradeNodeState
    corridor_ref            : Id
    fpic_status             : FPICStatus
    ej_zone_refs            : [Id]
    biotic_corridor_refs    : [Id]
    seasonal_restrictions   : [string]
    impact_score            : Decimal
    simulation_outcome_ref  : Id
}

// =============================================================================
// 13. Gate Evaluation Result
// =============================================================================

record BiodegradeGateResult {
    result_id               : Id
    context_id              : Id
    gate_id                 : Id
    decision                : GateDecision
    passed                  : Bool
    violation_atoms         : [Id]
    explanation             : string
    severity                : Severity
    conditions              : [string]
    remediation_steps       : [string]
    requires_human_review   : Bool
    citizen_notification    : Bool
    grievance_reference     : Id
    timestamp_unix          : Int
    governance_envelope_ref : Id
}

// =============================================================================
// 14. Gate Registry & Composition
// =============================================================================

record BiodegradeGateRegistry {
    registry_id             : Id
    version                 : string
    gates                   : [BiodegradeGate]
    habitat_buffer_gates    : [HabitatBufferGate]
    sewer_outfall_gates     : [SewerOutfallGate]
    wetland_protection_gates : [WetlandProtectionGate]
    canal_corridor_gates    : [CanalCorridorLimitGate]
    mar_vault_gates         : [MarVaultWaterQualityGate]
    indigenous_fpic_gates   : [IndigenousTerritoryFpicGate]
    ej_zone_gates           : [EjZoneToxicityCapGate]
    darkness_gates          : [BioticCorridorDarknessGate]
    seasonal_blackout_gates : [SeasonalBlackoutGate]
    decomposition_rate_gates : [DecompositionRateLimitGate]
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
    signature               : Id
}

// =============================================================================
// 15. Gate Composition Rules
// =============================================================================

record GateCompositionRule {
    rule_id                 : Id
    description             : string
    applicable_gate_types   : [BiodegradeGateType]
    composition_logic       : string
    conflict_resolution     : string
    priority_order          : [BiodegradeGateType]
    min_pass_threshold      : Decimal
    hard_block_gates        : [BiodegradeGateType]
    soft_penalty_gates      : [BiodegradeGateType]
}

// Canonical: All Hard Block Gates Must Pass
record Example_GateCompositionRule_HardBlock {
    rule : GateCompositionRule = {
        rule_id                     = "ALE-RULE-GATE-COMPOSITION-001"
        description                 = "All hard block gates must pass before any biodegrade actuation"
        applicable_gate_types       = [HABITAT_BUFFER, SEWER_OUTFALL_RESTRICTION, WETLAND_PROTECTION, INDIGENOUS_TERRITORY_FPIC, EJ_ZONE_TOXICITY_CAP]
        composition_logic           = "AND"
        conflict_resolution         = "highest_severity_wins"
        priority_order              = [INDIGENOUS_TERRITORY_FPIC, HABITAT_BUFFER, WETLAND_PROTECTION, SEWER_OUTFALL_RESTRICTION, EJ_ZONE_TOXICITY_CAP]
        min_pass_threshold          = 1.0
        hard_block_gates            = [HABITAT_BUFFER, SEWER_OUTFALL_RESTRICTION, WETLAND_PROTECTION, INDIGENOUS_TERRITORY_FPIC, EJ_ZONE_TOXICITY_CAP]
        soft_penalty_gates          = [DECOMPOSITION_RATE_LIMIT]
    }
}

// =============================================================================
// 16. Gate Override & Appeal Mechanisms
// =============================================================================

record GateOverrideRequest {
    override_id             : Id
    gate_id                 : Id
    context_id              : Id
    requested_by            : Id
    requested_at            : IsoTimestamp
    justification           : string
    supporting_evidence     : [Id]
    review_body_id          : Id
    review_deadline         : IsoTimestamp
    status                  : string
    decision                : string?
    decided_at              : IsoTimestamp?
    decided_by              : Id?
}

record GateAppealRecord {
    appeal_id               : Id
    override_id             : Id
    gate_result_id          : Id
    filed_by                : Id
    filed_at                : IsoTimestamp
    grounds                 : [string]
    supporting_documents    : [Id]
    review_body_id          : Id
    hearing_scheduled       : IsoTimestamp?
    decision                : string?
    decided_at              : IsoTimestamp?
    grievance_reference     : Id
}

