// =============================================================================
// 18. Audit & Ledger Integration
// =============================================================================

record BiodegradeGateAuditRecord {
    audit_id                : Id
    gate_result_id          : Id
    workflow_id             : Id
    node_id                 : Id
    decision                : GateDecision
    treaty_check_transcript : [Id]
    governance_envelope_id  : Id
