// =============================================================================
// 6. SMART Chain Composition Rules
// =============================================================================

record SmartChainCompositionRule {
    rule_id                 : Id
    description             : string
    applicable_domains      : [PolicyDomain]
    policy_refs             : [Id]
    composition_logic       : string
    conflict_resolution     : string
    priority_order          : [Id]
    min_pass_threshold      : Decimal
    hard_block_policies     : [Id]
    soft_penalty_policies   : [Id]
    override_requires       : [string]
}

// Canonical: All Hard Block Policies Must Pass
record Example_HardBlock_CompositionRule {
    rule : SmartChainCompositionRule = {
        rule_id                     = "ALE-SMART-RULE-COMPOSITION-001"
        description                 = "All hard block policies must pass before any biodegrade actuation"
        applicable_domains          = [WATER, WASTE, BIOTIC]
        policy_refs                 = [
            "ALE-SMART-CORRIDOR-WATER-001",
            "ALE-SMART-CORRIDOR-BIOTIC-001",
            "ALE-SMART-CORRIDOR-WASTE-001"
        ]
        composition_logic           = "AND"
        conflict_resolution         = "highest_severity_wins"
        priority_order              = [
            "ALE-SMART-BLOCK-FPIC-001",
            "ALE-SMART-BLOCK-EJ-TOXICITY-001",
            "ALE-SMART-DERATE-LYAPUNOV-001",
            "ALE-SMART-DERATE-TOXICITY-001"
        ]
        min_pass_threshold          = 1.0
        hard_block_policies         = [
            "ALE-SMART-BLOCK-FPIC-001",
            "ALE-SMART-BLOCK-EJ-TOXICITY-001"
        ]
        soft_penalty_policies       = [
            "ALE-SMART-DERATE-LYAPUNOV-001",
            "ALE-SMART-DERATE-TOXICITY-001"
        ]
        override_requires           = [
            "human_review_approval",
            "indigenous_consultation_if_applicable",
            "ej_community_notification_if_applicable",
            "ledger_append_before_override"
        ]
    }
}

// =============================================================================
// 7. Policy Evaluation Context & Result
// =============================================================================

record SmartChainPolicyContext {
    context_id              : Id
    workflow_id             : Id
    action_id               : Id
    node_id                 : Id
    domain                  : PolicyDomain
    corridor_id             : Id?
    birth_sign_id           : BirthSignId
    geo_tile_ref            : Id
    timestamp_unix          : Int
    proposed_action         : string
    action_parameters       : [string]
    current_node_state      : BiodegradeNodeState
    corridor_status         : CorridorDeclarationStatus
    fpic_status             : FPICStatus
    ej_zone_refs            : [Id]
    biotic_corridor_refs    : [Id]
    seasonal_restrictions   : [string]
    impact_score            : Decimal
    simulation_outcome_ref  : Id
    shard_refs              : [ShardId]
}

record SmartChainPolicyResult {
    result_id               : Id
    context_id              : Id
    policy_id               : Id
    decision                : Decision
    passed                  : Bool
    violated_policies       : [Id]
    applied_derates         : [Id]
    applied_blocks          : [Id]
    explanation             : string
    severity                : Severity
    conditions              : [string]
    remediation_steps       : [string]
    requires_human_review   : Bool
    citizen_notification    : Bool
    grievance_reference     : Id
    timestamp_unix          : Int
    governance_envelope_ref : Id
}

// =============================================================================
// 8. Policy Registry & Versioning
// =============================================================================

record SmartChainPolicyRegistry {
    registry_id             : Id
    version                 : string
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
    corridor_policies       : [CorridorDeclarationPolicy]
    ingestion_policies      : [ShardIngestionPolicy]
    derate_policies         : [DeratePolicy]
    block_policies          : [BlockPolicy]
    domain_policies         : [WaterDomainSmartPolicy, BioticDomainSmartPolicy, WasteDomainSmartPolicy]
    composition_rules       : [SmartChainCompositionRule]
    signature               : PQSignature
    authoring_body_did      : DID
    ratification_timestamp  : IsoTimestamp
}

record SmartChainPolicyVersion {
    version_id              : Id
    policy_id               : Id
    version_number          : Int
    changelog               : [string]
    superseded_by           : Id?
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
    migration_required      : Bool
    migration_instructions  : [string]
}

// =============================================================================
// 9. Audit & Compliance Records
// =============================================================================

record SmartChainPolicyAudit {
    audit_id                : Id
    policy_id               : Id
    audit_timestamp         : IsoTimestamp
    auditor_did             : DID
    audit_type              : string
    policy_enforcement_verified : Bool
    treaty_compliance_verified : Bool
    fpic_verified           : Bool
    ej_compliance_verified  : Bool
    biotic_compliance_verified : Bool
    violations_found        : Int
    violations_refs         : [Id]
    remediation_required    : Bool
    remediation_deadline    : IsoTimestamp?
    audit_signature         : PQSignature
    ledger_reference        : Id
}

record SmartChainComplianceTranscript {
    transcript_id           : Id
    context_id              : Id
    timestamp               : IsoTimestamp
    policies_evaluated      : [Id]
    corridor_check_result   : string
    ingestion_check_result  : string
    derate_check_result     : string
    block_check_result      : string
    fpic_check_result       : string
    ej_check_result         : string
    biotic_check_result     : string
    overall_compliance      : Bool
    violated_policies       : [Id]
    applied_policies        : [Id]
    explanation             : string
    grievance_reference     : Id
}

// =============================================================================
// 10. Citizen Notification & Grievance Templates
// =============================================================================

record SmartChainNotificationTemplate {
    template_id             : Id
    policy_type             : string
    language                : string
    title_template          : string
    body_template           : string
    action_links            : [string]
    grievance_link_template : string
    contact_info_template   : string
}

// Canonical: English Notification for Derate Action
record Example_DerateNotification_English {
    template : SmartChainNotificationTemplate = {
        template_id                 = "ALE-NOTIFY-DERATE-EN-001"
        policy_type                 = "derate"
        language                    = "en"
        title_template              = "Biodegradable Node Operation Derated"
        body_template               = "A biodegradable node operation in {domain} has been derated due to {trigger_condition}. Derate factor: {derate_factor}. Duration: {derate_duration_hours} hours. Ecosafety score: {ecosafety_score}."
        action_links                = ["View Details", "File Grievance", "Contact Representatives"]
        grievance_link_template     = "https://aletheion.phoenix/grievance/{grievance_ref}"
        contact_info_template       = "Domain Representative: {representative_contact}"
    }
}

// Canonical: English Notification for Block Action
record Example_BlockNotification_English {
    template : SmartChainNotificationTemplate = {
        template_id                 = "ALE-NOTIFY-BLOCK-EN-001"
        policy_type                 = "block"
        language                    = "en"
        title_template              = "Biodegradable Node Operation Blocked"
        body_template               = "A biodegradable node operation in {domain} has been blocked due to {trigger_condition}. Block duration: {block_duration_hours} hours. Human review required: {human_review_required}. Grievance auto-filed: {grievance_auto_file}."
        action_links                = ["View Details", "File Appeal", "Request Human Review"]
        grievance_link_template     = "https://aletheion.phoenix/grievance/{grievance_ref}"
        contact_info_template       = "Domain Representative: {representative_contact}"
    }
}

// Canonical: O'odham Notification for Indigenous Territory Block
record Example_IndigenousBlockNotification_Oodham {
    template : SmartChainNotificationTemplate = {
        template_id                 = "ALE-NOTIFY-INDIGENOUS-BLOCK-OODHAM-001"
        policy_type                 = "block"
        language                    = "ood"
        title_template              = "Haʼkohwóóʼ Áłtsé Hoolʼą́ą́ʼ"
        body_template               = "Biodegradable node activity blocked in Akimel O'odham territory. FPIC status: {fpic_status}. Consultation required: {consultation_required}."
        action_links                = ["View Details", "Request Consultation", "File Grievance"]
        grievance_link_template     = "https://aletheion.phoenix/grievance/{grievance_ref}"
        contact_info_template       = "Council Contact: {council_contact}"
    }
}

// =============================================================================
// 11. SMART Chain Engine Contract (Rust Binding Interface)
// =============================================================================

// This defines the boundary that Rust SMART chain evaluators must honor.
// In Rust, each policy evaluator would expose a function equivalent to:
//
//   fn evaluate_policy(ctx: SmartChainPolicyContext, policy: SmartChainPolicy) -> SmartChainPolicyResult;
//
// An orchestrator composes multiple policy results into an overall decision
// and ensures that any BLOCK decisions prevent actuation before
// appending to Googolswarm provenance envelopes.

record SmartChainEngineContract {
    engine_id               : Id
    description             : string
    accepts_domains         : [PolicyDomain]
    accepts_policy_types    : [string]
    requires_birth_sign     : Bool
    requires_fpic           : Bool
    requires_ej_zones       : Bool
    requires_biotic_refs    : Bool
    requires_corridor_decl  : Bool
    requires_shard_refs     : Bool
    output_schema_ref       : Id
    version                 : string
}

record SmartChainEngineRegistry {
    registry_id             : Id
    engines                 : [SmartChainEngineContract]
    version                 : string
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
}

// =============================================================================
// 12. Canonical Phoenix Policy Bindings
// =============================================================================

record PhoenixSmartChainBinding {
    binding_id              : Id
    city_jurisdiction       : string = "Phoenix, Arizona"
    applicable_domains      : [PolicyDomain]
    policy_registry_ref     : Id
    treaty_os_ref           : Id
    birth_sign_resolver_ref : Id
    ecosafety_contract_ref  : Id
    googolswarm_client_ref  : Id
    citizen_interface_ref   : Id
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
    city_council_resolution : string
    indigenous_agreement_ref : Id
    ej_zone_designation_ref : Id
}

// Canonical: Phoenix Aletheion Deployment Binding
record Example_Phoenix_AletheionBinding {
    binding : PhoenixSmartChainBinding = {
        binding_id                    = "ALE-PHX-SMART-BINDING-001"
        applicable_domains            = [WATER, WASTE, BIOTIC, SOIL, THERMAL]
        policy_registry_ref           = "ALE-SMART-REGISTRY-PHX-001"
        treaty_os_ref                 = "ALE-TREATY-OS-001"
        birth_sign_resolver_ref       = "ALE-BIRTHSIGN-RESOLVER-001"
        ecosafety_contract_ref        = "ALE-ECOSAFETY-CONTRACT-001"
        googolswarm_client_ref        = "ALE-GOOGOLSWARM-CLIENT-001"
        citizen_interface_ref         = "ALE-CITIZEN-INTERFACE-001"
        valid_from                    = "2025-01-01T00:00:00Z"
        valid_until                   = "2035-12-31T23:59:59Z"
        city_council_resolution       = "PHX-RES-2024-SMARTCITY-001"
        indigenous_agreement_ref      = "AGREEMENT-AKIMEL-OODHAM-001"
        ej_zone_designation_ref       = "EJ-PHX-DESIGNATION-001"
    }
}

// End of Aletheion Governance SMART Chain Biodegrade Policy Set
