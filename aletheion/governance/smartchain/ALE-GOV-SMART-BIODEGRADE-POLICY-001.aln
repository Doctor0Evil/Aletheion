// Aletheion Governance SMART Chain Biodegrade Policy Set
// File: ALE-GOV-SMART-BIODEGRADE-POLICY-001.aln
// Domain: Governance / SMART Chain / Biodegrade Policy Enforcement
// Compliance: BioticTreaties, Indigenous FPIC, EJ Zones, Ecosafety Contracts

aln_version 1.0
namespace Aletheion.Governance.SmartChain.Biodegrade

import Aletheion.ERM.Ecosafety.Biodegrade
import Aletheion.Governance.Lexethos.Biodegrade
import Aletheion.Trust.Schemas.Biodegrade
import Aletheion.TreatyOS

// =============================================================================
// 1. Core Policy Types & Enums
// =============================================================================

enum PolicyEnforcementLevel {
    MANDATORY
    RECOMMENDED
    ADVISORY
    PROHIBITED
}

enum PolicyDomain {
    WATER
    WASTE
    BIOTIC
    SOIL
    AIR
    THERMAL
}

enum CorridorDeclarationStatus {
    REQUIRED
    DECLARED
    ACTIVE
    EXPIRED
    VIOLATED
    NOT_REQUIRED
}

enum ShardIngestionRule {
    ALLOW
    REQUIRE_VALIDATION
    REQUIRE_MULTISIG
    BLOCK
    QUARANTINE
}

enum DerateTrigger {
    LYAPUNOV_UNSTABLE
    TOXICITY_ELEVATED
    CORRIDOR_MARGIN_LOW
    SEASONAL_RESTRICTION
    FPIC_PENDING
    EJ_ZONE_ACTIVE
    BIOTIC_CORRIDOR_OVERLAP
}

record SmartChainPolicyHeader {
    policy_id               : Id
    policy_version          : Int
    namespace               : string
    valid_from              : IsoTimestamp
    valid_until             : IsoTimestamp
    superseded_by           : Id?
    signature               : PQSignature
    authoring_body_did      : DID
    ratification_timestamp  : IsoTimestamp
}

// =============================================================================
// 2. Corridor Declaration Policies
// =============================================================================

record CorridorDeclarationPolicy {
    policy_id               : Id
    domain                  : PolicyDomain
    requires_declaration    : Bool
    declaration_validity_days : Int
    renewal_notice_days     : Int
    auto_expire_on_violation : Bool
    min_integrity_score     : Decimal
    max_nodes_per_corridor  : Int
    max_total_mass_grams    : Decimal
    enforcement_level       : PolicyEnforcementLevel
    hard_block_conditions   : [string]
    derate_conditions       : [string]
}

// Canonical: Water Domain Corridor Declaration (Phoenix Canal System)
record Example_WaterDomain_CorridorPolicy {
    policy : CorridorDeclarationPolicy = {
        policy_id                     = "ALE-SMART-CORRIDOR-WATER-001"
        domain                        = WATER
        requires_declaration          = true
        declaration_validity_days     = 90
        renewal_notice_days           = 14
        auto_expire_on_violation      = true
        min_integrity_score           = 0.85
        max_nodes_per_corridor        = 50
        max_total_mass_grams          = 10000.0
        enforcement_level             = MANDATORY
        hard_block_conditions         = [
            "corridor_status == UNDECLARED",
            "corridor_status == VIOLATED",
            "integrity_score < 0.70",
            "fpic_status == DENIED"
        ]
        derate_conditions             = [
            "integrity_score < 0.85",
            "renewal_overdue == true",
            "lyapunov_unstable_nodes > 0"
        ]
    }
}

// Canonical: Biotic Domain Corridor Declaration (Riparian Corridors)
record Example_BioticDomain_CorridorPolicy {
    policy : CorridorDeclarationPolicy = {
        policy_id                     = "ALE-SMART-CORRIDOR-BIOTIC-001"
        domain                        = BIOTIC
        requires_declaration          = true
        declaration_validity_days     = 60
        renewal_notice_days           = 21
        auto_expire_on_violation      = true
        min_integrity_score           = 0.90
        max_nodes_per_corridor        = 20
        max_total_mass_grams          = 3000.0
        enforcement_level             = MANDATORY
        hard_block_conditions         = [
            "corridor_status == UNDECLARED",
            "biotic_treaty_violation == true",
            "darkness_violation == true",
            "protected_species_present && toxicity > 1.0"
        ]
        derate_conditions             = [
            "integrity_score < 0.90",
            "seasonal_blackout_approaching == true",
            "native_plant_fraction < 0.6"
        ]
    }
}

// Canonical: Waste Domain Corridor Declaration (Sewer/Outfall)
record Example_WasteDomain_CorridorPolicy {
    policy : CorridorDeclarationPolicy = {
        policy_id                     = "ALE-SMART-CORRIDOR-WASTE-001"
        domain                        = WASTE
        requires_declaration          = true
        declaration_validity_days     = 30
        renewal_notice_days           = 7
        auto_expire_on_violation      = true
        min_integrity_score           = 0.80
        max_nodes_per_corridor        = 100
        max_total_mass_grams          = 20000.0
        enforcement_level             = MANDATORY
        hard_block_conditions         = [
            "corridor_status == UNDECLARED",
            "downstream_toxicity_exceeded == true",
            "receiving_water_body_violation == true"
        ]
        derate_conditions             = [
            "dilution_factor < 10.0",
            "alert_threshold_approaching == true"
        ]
    }
}

// =============================================================================
// 3. Shard Ingestion Policies
// =============================================================================

record ShardIngestionPolicy {
    policy_id               : Id
    shard_type              : string
    ingestion_rule          : ShardIngestionRule
    required_validations    : [string]
    required_signatures     : Int
    required_attestations   : [string]
    treaty_check_required   : Bool
    fpic_binding_required   : Bool
    ej_zone_enhanced_review : Bool
    biotic_treaty_binding   : Bool
    lyapunov_trace_required : Bool
    toxicity_trace_required : Bool
    quarantine_days         : Int
    public_accessible_after : Int
}

// Canonical: Decomposition Experiment Shard Ingestion
record Example_DecompositionShard_IngestionPolicy {
    policy : ShardIngestionPolicy = {
        policy_id                     = "ALE-SMART-INGEST-DECOMP-001"
        shard_type                    = "decomposition_experiment"
        ingestion_rule                = REQUIRE_VALIDATION
        required_validations          = [
            "material_provenance_verified",
            "corridor_declaration_active",
            "lyapunov_trace_complete",
            "toxicity_trace_complete"
        ]
        required_signatures           = 2
        required_attestations         = [
            "principal_investigator",
            "ecosafety_contract"
        ]
        treaty_check_required         = true
        fpic_binding_required         = true
        ej_zone_enhanced_review       = true
        biotic_treaty_binding         = true
        lyapunov_trace_required       = true
        toxicity_trace_required       = true
        quarantine_days               = 7
        public_accessible_after       = 30
    }
}

// Canonical: Leachate Monitoring Shard Ingestion
record Example_LeachateShard_IngestionPolicy {
    policy : ShardIngestionPolicy = {
        policy_id                     = "ALE-SMART-INGEST-LEACHATE-001"
        shard_type                    = "leachate_monitoring"
        ingestion_rule                = REQUIRE_MULTISIG
        required_validations          = [
            "chain_of_custody_verified",
            "lab_accreditation_verified",
            "epa_method_compliance"
        ]
        required_signatures           = 3
        required_attestations         = [
            "sample_collector",
            "lab_analyst",
            "quality_control_officer"
        ]
        treaty_check_required         = true
        fpic_binding_required         = false
        ej_zone_enhanced_review       = true
        biotic_treaty_binding         = false
        lyapunov_trace_required       = false
        toxicity_trace_required       = true
        quarantine_days               = 0
        public_accessible_after       = 7
    }
}

// Canonical: Corridor Update Shard Ingestion
record Example_CorridorUpdate_IngestionPolicy {
    policy : ShardIngestionPolicy = {
        policy_id                     = "ALE-SMART-INGEST-CORRIDOR-001"
        shard_type                    = "corridor_update"
        ingestion_rule                = REQUIRE_MULTISIG
        required_validations          = [
            "integrity_score_recalculated",
            "node_count_verified",
            "violation_count_verified"
        ]
        required_signatures           = 3
        required_attestations         = [
            "corridor_administrator",
            "ecosafety_contract",
            "birth_sign_resolver"
        ]
        treaty_check_required         = true
        fpic_binding_required         = true
        ej_zone_enhanced_review       = false
        biotic_treaty_binding         = true
        lyapunov_trace_required       = true
        toxicity_trace_required       = true
        quarantine_days               = 3
        public_accessible_after       = 1
    }
}

// =============================================================================
// 4. Derate & Block Policies
// =============================================================================

record DeratePolicy {
    policy_id               : Id
    trigger_condition       : DerateTrigger
    derate_factor           : Decimal
    derate_duration_hours   : Int
    escalation_rule         : string
    recovery_conditions     : [string]
    notification_required   : Bool
    citizen_explanation_template : Id
}

record BlockPolicy {
    policy_id               : Id
    trigger_condition       : string
    block_duration_hours    : Int
    human_review_required   : Bool
    appeal_window_hours     : Int
    grievance_auto_file     : Bool
    indigenous_consultation_required : Bool
    ej_community_notification_required : Bool
}

// Canonical: Lyapunov Instability Derate
record Example_LyapunovDerate_Policy {
    policy : DeratePolicy = {
        policy_id                     = "ALE-SMART-DERATE-LYAPUNOV-001"
        trigger_condition             = LYAPUNOV_UNSTABLE
        derate_factor                 = 0.5
        derate_duration_hours         = 24
        escalation_rule               = "if unstable_count > 3 then block"
        recovery_conditions           = [
            "lyapunov_stable == true",
            "convergence_verified == true",
            "ecosafety_contract_approval == true"
        ]
        notification_required         = true
        citizen_explanation_template  = "ALE-EXPLAIN-DERATE-LYAPUNOV-001"
    }
}

// Canonical: Toxicity Elevated Derate
record Example_ToxicityDerate_Policy {
    policy : DeratePolicy = {
        policy_id                     = "ALE-SMART-DERATE-TOXICITY-001"
        trigger_condition             = TOXICITY_ELEVATED
        derate_factor                 = 0.3
        derate_duration_hours         = 48
        escalation_rule               = "if toxicity > threshold * 2 then block"
        recovery_conditions           = [
            "toxicity_below_threshold == true",
            "flush_complete == true",
            "downstream_sensor_clear == true"
        ]
        notification_required         = true
        citizen_explanation_template  = "ALE-EXPLAIN-DERATE-TOXICITY-001"
    }
}

// Canonical: FPIC Pending Block
record Example_FpicPending_BlockPolicy {
    policy : BlockPolicy = {
        policy_id                     = "ALE-SMART-BLOCK-FPIC-001"
        trigger_condition             = "fpic_status == REQUIRED_PENDING"
        block_duration_hours          = 0
        human_review_required         = true
        appeal_window_hours           = 72
        grievance_auto_file           = false
        indigenous_consultation_required = true
        ej_community_notification_required = false
    }
}

// Canonical: EJ Zone Toxicity Block
record Example_EJToxicity_BlockPolicy {
    policy : BlockPolicy = {
        policy_id                     = "ALE-SMART-BLOCK-EJ-TOXICITY-001"
        trigger_condition             = "ej_zone_flag == true && toxicity > ej_cap"
        block_duration_hours          = 168
        human_review_required         = true
        appeal_window_hours           = 72
        grievance_auto_file           = true
        indigenous_consultation_required = false
        ej_community_notification_required = true
    }
}

// =============================================================================
// 5. Domain-Specific SMART Policies
// =============================================================================

record WaterDomainSmartPolicy {
    policy_id               : Id
    domain                  : PolicyDomain = WATER
    corridor_policy_ref     : Id
    ingestion_policy_ref    : Id
    derate_policies         : [Id]
    block_policies          : [Id]
    fpic_requirement_ref    : Id
    indigenous_water_rights_ref : Id
    drought_tier_rules      : [string]
    max_withdrawal_cfs      : Decimal
    max_annual_volume_af    : Decimal
    monitoring_frequency_hours : Int
    alert_thresholds        : [string]
}

// Canonical: Phoenix Canal Water Domain Policy
record Example_PhoenixCanal_WaterPolicy {
    policy : WaterDomainSmartPolicy = {
        policy_id                     = "ALE-SMART-WATER-PHX-CANAL-001"
        corridor_policy_ref           = "ALE-SMART-CORRIDOR-WATER-001"
        ingestion_policy_ref          = "ALE-SMART-INGEST-DECOMP-001"
        derate_policies               = [
            "ALE-SMART-DERATE-LYAPUNOV-001",
            "ALE-SMART-DERATE-TOXICITY-001"
        ]
        block_policies                = [
            "ALE-SMART-BLOCK-FPIC-001",
            "ALE-SMART-BLOCK-EJ-TOXICITY-001"
        ]
        fpic_requirement_ref          = "ALE-FPIC-WATER-INDIGENOUS-001"
        indigenous_water_rights_ref   = "WATER-RIGHTS-AKIMEL-OODHAM-001"
        drought_tier_rules            = [
            "tier_0: normal_operations",
            "tier_1: reduce_15_percent",
            "tier_2: reduce_30_percent",
            "tier_3: emergency_only"
        ]
        max_withdrawal_cfs            = 50.0
        max_annual_volume_af          = 1000.0
        monitoring_frequency_hours    = 6
        alert_thresholds              = [
            "toxicity > 3.0 ppb",
            "lyapunov_residual > 0.5",
            "flow_rate < 10 cfs"
        ]
    }
}

record BioticDomainSmartPolicy {
    policy_id               : Id
    domain                  : PolicyDomain = BIOTIC
    corridor_policy_ref     : Id
    ingestion_policy_ref    : Id
    derate_policies         : [Id]
    block_policies          : [Id]
    biotic_treaty_refs      : [Id]
    species_agent_refs      : [SpeciesAgentRef]
    darkness_requirements   : [string]
    noise_requirements      : [string]
    pesticide_bans          : [string]
    seasonal_blackout_rules : [string]
    habitat_buffer_meters   : Decimal
}

// Canonical: Phoenix Riparian Bat Corridor Policy
record Example_PhoenixRiparian_BioticPolicy {
    policy : BioticDomainSmartPolicy = {
        policy_id                     = "ALE-SMART-BIOTIC-PHX-RIPARIAN-001"
        corridor_policy_ref           = "ALE-SMART-CORRIDOR-BIOTIC-001"
        ingestion_policy_ref          = "ALE-SMART-INGEST-DECOMP-001"
        derate_policies               = [
            "ALE-SMART-DERATE-LYAPUNOV-001"
        ]
        block_policies                = [
            "ALE-SMART-BLOCK-FPIC-001"
        ]
        biotic_treaty_refs            = [
            "ALE-BIOTIC-BAT-CANAL-CORRIDOR-001"
        ]
        species_agent_refs            = [
            { species_agent_id = "SPECIES-MYOTIS-VELIFER" }
        ]
        darkness_requirements         = [
            "max_lux_corridor <= 3.0",
            "dark_hours 18:00-06:00",
            "amber_spectrum_only"
        ]
        noise_requirements            = [
            "max_db_night <= 45.0",
            "impulsive_noise_penalty == 0.5"
        ]
