            "NEONICOTINOID",
            "PYRETHROID"
        ]
        seasonal_blackout_rules       = [
            "breeding_season: March 1 - August 31",
            "no_actuation_during_blackout"
        ]
        habitat_buffer_meters         = 50.0
    }
}

record WasteDomainSmartPolicy {
    policy_id               : Id
    domain                  : PolicyDomain = WASTE
    corridor_policy_ref     : Id
    ingestion_policy_ref    : Id
    derate_policies         : [Id]
    block_policies          : [Id]
    outfall_policies        : [Id]
    receiving_water_body_refs : [Id]
    dilution_factor_min     : Decimal
    downstream_sensor_refs  : [Id]
    alert_threshold_ppb     : Decimal
    shutdown_threshold_ppb  : Decimal
    sampling_frequency_hours : Int
}

