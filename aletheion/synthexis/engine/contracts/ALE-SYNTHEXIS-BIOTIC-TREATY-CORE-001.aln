// ============================================================================
// FILE: aletheion/synthexis/engine/contracts/ALE-SYNTHEXIS-BIOTIC-TREATY-CORE-001.aln
// PURPOSE: Core treaty schema for SpeciesAgent definitions, corridor constraints,
//          LNP (Light/Noise/Pesticide) limits, and habitat continuity requirements
// LANGUAGE: ALN (Aletheion Logic Notation) - Version 001
// DESTINATION: Aletheion Repository - Synthexis Engine Contracts Subsystem
// COMPLIANCE: Zero-contamination IFC, NeurorightsEnvelope, FPIC metadata,
//             Sonoran Desert ecosystem preservation, BioticTreaty enforcement
// AUTHORITY: Single semantic source - All Rust engines read this schema
// RELATED: ALE-SYNTHEXIS-IFC-KERNEL-001.rs, ALE-HIGHWAYS-CORRIDOR-POLICIES-001.aln
// ============================================================================

@version "001"
@domain "aletheion.synthexis.contracts"
@policy_type "biotic_treaty_core"
@effective_date "2026-03-08T00:00:00Z"
@jurisdiction "Phoenix, Arizona, USA"
@indigenous_territory "Akimel O'odham and Piipaash ancestral lands"

// ============================================================================
// SECTION 1: SPECIES AGENT SCHEMA DEFINITIONS
// ============================================================================

@species_agent_schema {
    name: "Aletheion_SpeciesAgent"
    version: "001"
    
    @field agent_id {
        type: "string"
        pattern: "^SA-[0-9]{6}-[A-Z]{4}$"
        required: true
        immutable: true
        description: "Unique species agent identifier"
    }
    
    @field species_name {
        type: "string"
        pattern: "^[A-Za-z]+ [a-z]+$"
        required: true
        immutable: true
        description: "Binomial nomenclature (Genus species)"
    }
    
    @field common_name {
        type: "string"
        required: false
        mutable: true
        description: "Common name in English"
    }
    
    @field oodham_name {
        type: "string"
        required: false
        mutable: true
        description: "Name in O'odham language for indigenous knowledge integration"
    }
    
    @field class {
        type: "enum"
        allowed_values: [pollinator, avian, mammalian, reptilian, amphibian, keystone, indicator]
        required: true
        mutable: false
        description: "Species agent classification"
    }
    
    @field population_estimate {
        type: "unsigned_integer"
        min: 0
        max: 1000000000
        required: true
        mutable: true
        description: "Estimated population in region"
    }
    
    @field population_trend {
        type: "enum"
        allowed_values: [increasing, stable, declining, critical]
        required: true
        mutable: true
        description: "Population trend direction"
    }
    
    @field threat_level {
        type: "float"
        min: 0.0
        max: 1.0
        required: true
        mutable: true
        description: "Threat level normalized score"
    }
    
    @field corridor_dependency {
        type: "float"
        min: 0.0
        max: 1.0
        required: true
        mutable: false
        description: "Dependency on wildlife corridors"
    }
    
    @field habitat_requirements {
        type: "array"
        item_type: "enum"
        allowed_values: [desert_scrub, riparian_corridor, urban_green_space, pollinator_corridor, wildlife_crossing, native_restoration, conservation_easement]
        required: true
        mutable: false
        description: "Required habitat types"
    }
    
    @field fpic_verified {
        type: "boolean"
        required: true
        mutable: false
        description: "Free, Prior, and Informed Consent verification"
    }
    
    @field indigenous_knowledge_integrated {
        type: "boolean"
        required: true
        mutable: false
        description: "Indigenous ecological knowledge integration status"
    }
    
    @field conservation_priority {
        type: "float"
        min: 0.0
        max: 1.0
        required: true
        mutable: true
        description: "Computed conservation priority score"
    }
    
    @invariant species_invariant_001 {
        description: "All keystone species require FPIC verification"
        condition: class == keystone => fpic_verified == true
        enforcement: hard_block
    }
    
    @invariant species_invariant_002 {
        description: "Pollinator species require indigenous knowledge integration"
        condition: class == pollinator => indigenous_knowledge_integrated == true
        enforcement: hard_block
    }
    
    @invariant species_invariant_003 {
        description: "Threat level must be updated quarterly"
        condition: threat_level_last_updated <= 90_days_ago
        enforcement: soft_warning
    }
}

@species_registry {
    name: "Sonoran_Desert_Species_Registry"
