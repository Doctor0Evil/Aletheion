TITLE ALE-SYN-SPECIES-AGENT-SONORAN-001
ROLE  Synthexis Cross-Species Interface – Sonoran Urban Biome Catalog
LAYER L2-L4
BIRTH_SIGN Desert/Sonoran

// ---------------------------------------------------------------------
// 0. Core type grammar – Synthexis Sonoran schema
// ---------------------------------------------------------------------

TYPE Birth_Sign =
  | Desert_Sonoran
;

TYPE Taxon_Class =
  | Mammal
  | Bird
  | Reptile
  | Amphibian
  | Fish
  | Invertebrate
  | Plant
  | Fungi
;

TYPE Habitat_Stratum =
  | Ground
  | Arboreal
  | Aerial
  | Riparian
  | Aquatic
  | Subterranean
  | Indoor_Domestic
  | Indoor_Commercial
;

TYPE Water_Dependency =
  | Minimal
  | Moderate
  | High
;

TYPE Light_Profile =
  | Diurnal
  | Crepuscular
  | Nocturnal
  | Cathemeral
;

TYPE Noise_Sensitivity_Level =
  | Low
  | Medium
  | High
  | Extreme
;

TYPE Chemical_Risk_Level =
  | Low
  | Medium
  | High
;

TYPE Pesticide_Avoid_Class =
  | None
  | Insecticide
  | Rodenticide
  | Herbicide
  | Broad_Spectrum
;

TYPE Season_Tag =
  | Winter
  | Spring
  | Summer
  | Fall
  | Monsoon
;

TYPE Ecosystem_Service_Tag =
  | Pollination
  | Pest_Control
  | Seed_Dispersal
  | Scavenging
  | Soil_Health
  | Decomposition
  | Cultural_Symbolic
  | Food_Web_Keystone
;

TYPE Human_Risk_Tag =
  | Zoonosis_Risk
  | Allergen_Risk
  | Bite_Sting_Risk
  | Infrastructure_Damage_Risk
  | Vectoring_Pesticide_Exposure
  | Minimal_Risk
;

TYPE Infra_Domain =
  | Street_Lighting
  | Building_Facade_Lighting
  | XR_Display
  | XR_Audio
  | XR_Haptics
  | Cooling_Asset
  | Pesticide_Program
  | Waste_Handling
  | Sewer_Stormwater
  | Canal_Wetland
  | Rooftop_Solar
  | Traffic_Noise
  | Rail_Aviation_Noise
;

TYPE Risk_Coord_Name =
  | ALAN_Lux
  | ALAN_Blue_Fraction
  | Noise_dBA
  | Peak_Noise_dBC
  | Air_Temp_C
  | Surface_Temp_C
  | Pesticide_Dose_Index
  | Particulate_Load_Index
;

TYPE Corridor_Policy =
  | Hard_Limit
  | Soft_Limit_Derate
;

RECORD Risk_Coord_Band {
  coord_name      : Risk_Coord_Name,
  min_safe        : Float,      // normalized 0–1 corridor min
  max_safe        : Float,      // normalized 0–1 corridor max
  policy          : Corridor_Policy
}

RECORD Seasonal_Window {
  seasons         : [Season_Tag],
  local_note      : String      // e.g., "bat commuting over canals at nautical twilight"
}

RECORD Species_Taxon {
  kingdom         : String,
  phylum          : String,
  class           : Taxon_Class,
  order           : String,
  family          : String,
  genus           : String,
  species         : String,
  common_name     : String
}

RECORD Habitat_Requirements {
  strata          : [Habitat_Stratum],
  water_need      : Water_Dependency,
  shade_needed    : Bool,
  cooling_asset_ok: Bool,       // can share cooled corridors with humans
  indoor_compatible: Bool       // survives in built indoor Sonoran settings
}

RECORD Light_Envelope {
  profile         : Light_Profile,
  light_averse    : Bool,
  max_lux_corridor: Float,      // normalized ALAN_Lux bound for corridors
  max_lux_foraging: Float,      // normalized ALAN_Lux bound for foraging/rest
  avoid_blue_frac : Float       // fraction of 400–500 nm to avoid (0–1)
}

RECORD Noise_Envelope {
  sensitivity     : Noise_Sensitivity_Level,
  max_dBA_night   : Float,      // normalized Noise_dBA threshold
  impulsive_penalty: Float,     // 0–1 cost for fireworks, sirens, etc.
  continuous_penalty: Float     // 0–1 cost for traffic, HVAC drones
}

RECORD Chemical_Envelope {
  risk_level      : Chemical_Risk_Level,
  avoided_classes : [Pesticide_Avoid_Class],
  drift_distance_m: Float,      // indicative buffer distance
  particulate_sensitivity: Float // normalized Particulate_Load_Index
}

RECORD Seasonal_Sensitivity {
  active          : [Seasonal_Window],
  breeding        : [Seasonal_Window],
  migration       : [Seasonal_Window],
  critical_dark   : [Seasonal_Window] // windows requiring strict ALAN and noise control
}

RECORD Priority_Weights {
  conservation    : Float,      // 0–1
  ecosystem       : [Ecosystem_Service_Tag],
  ecosystem_weight: Float,      // 0–1
  cultural_weight : Float,      // 0–1
  human_risks     : [Human_Risk_Tag],
  human_risk_weight: Float      // 0–1
}

RECORD SpeciesAgent {
  id              : String,     // stable key e.g., "canis_lupus_familiaris_dog"
  birth_sign      : Birth_Sign,
  taxon           : Species_Taxon,
  habitat         : Habitat_Requirements,
  light_env       : Light_Envelope,
  noise_env       : Noise_Envelope,
  chemical_env    : Chemical_Envelope,
  seasonal        : Seasonal_Sensitivity,
  priority        : Priority_Weights
}

// BioticTreaty ties SpeciesAgents to infrastructure and ecosafety corridors.

RECORD BioticTreaty {
  treaty_id       : String,
  birth_sign      : Birth_Sign,
  species_ids     : [String],        // SpeciesAgent.id
  infra_domains   : [Infra_Domain],
  spatial_scope   : String,         // e.g., corridor/neighborhood/canal id
  temporal_scope  : [Seasonal_Window],
  risk_bands      : [Risk_Coord_Band],
  ecosafety_corridor_ids : [String], // refs into ALE-ERM-ECOSAFETY-GRAMMAR-001
  enforcement_mode: String,         // "Hard", "Advisory"
  notes           : String
}

// Cross-species interface contracts bind human neurorights and nonhuman envelopes.

TYPE Neuroright_Envelope =
  | Soma_Safety
  | Cognitive_Load
  | Emotion_Fear
  | Emotion_Pain
  | Emotion_Sanity
;

RECORD CrossSpeciesInterfaceContract {
  contract_id     : String,
  birth_sign      : Birth_Sign,
  human_neurorights : [Neuroright_Envelope],
  species_ids     : [String],
  infra_domains   : [Infra_Domain],
  risk_bands      : [Risk_Coord_Band],
  notes           : String
}

