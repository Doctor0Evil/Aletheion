// ---------------------------------------------------------------------
// 5. Example Sonoran BioticTreaties binding to ecosafety corridors
// ---------------------------------------------------------------------

BIOTIC_TREATY bt_sonoran_bats_riparian_dark_corridors {
  treaty_id   = "BT-SONORAN-BATS-RIPARIAN-DARK-001";
  birth_sign  = Desert_Sonoran;
  species_ids = ["bat_guild_sonoran_commuter"];
  infra_domains = [Street_Lighting, Building_Facade_Lighting, Canal_Wetland, XR_Display];
  spatial_scope = "Riparian_and_canal_corridors_Phoenix_Metro";
  temporal_scope = [
    {seasons=[Spring,Summer,Fall,Monsoon]; local_note="Nautical twilight to pre-dawn along canals and rivers."}
  ];
  risk_bands = [
    {coord_name=ALAN_Lux;          min_safe=0.00; max_safe=0.20; policy=Hard_Limit},
    {coord_name=ALAN_Blue_Fraction;min_safe=0.00; max_safe=0.20; policy=Hard_Limit},
    {coord_name=Noise_dBA;         min_safe=0.00; max_safe=0.40; policy=Soft_Limit_Derate},
    {coord_name=Pesticide_Dose_Index;min_safe=0.00; max_safe=0.20; policy=Hard_Limit}
  ];
  ecosafety_corridor_ids = ["MARDESERTPFASV1", "CANALDARKBIOTICBATV1"];
  enforcement_mode = "Hard";
  notes = "Enforce dark, low-noise, low-pesticide corridors for commuting bats along Phoenix riparian and canal systems.";
}

BIOTIC_TREATY bt_sonoran_native_bees_pollinator_network {
  treaty_id   = "BT-SONORAN-NATIVE-BEES-001";
  birth_sign  = Desert_Sonoran;
  species_ids = ["native_bee_guild_sonoran"];
  infra_domains = [Pesticide_Program, Cooling_Asset, Rooftop_Solar, Waste_Handling];
  spatial_scope = "Pollinator_citywide_network_Sonoran_Plants";
  temporal_scope = [
    {seasons=[Spring,Summer,Monsoon]; local_note="Peak native bee foraging and nesting."}
  ];
  risk_bands = [
    {coord_name=Pesticide_Dose_Index;min_safe=0.00; max_safe=0.15; policy=Hard_Limit},
    {coord_name=Particulate_Load_Index;min_safe=0.00; max_safe=0.50; policy=Soft_Limit_Derate}
  ];
  ecosafety_corridor_ids = ["SONORANPOLLINATORCHEMICALV1"];
  enforcement_mode = "Hard";
  notes = "Limits insecticide and broad-spectrum pesticide use near native pollinator corridors and Sonoran Desert plantings.";
}

BIOTIC_TREATY bt_sonoran_owl_quiet_roosts {
  treaty_id   = "BT-SONORAN-OWL-QUIET-001";
  birth_sign  = Desert_Sonoran;
  species_ids = ["bubo_virginianus_great_horned_owl"];
  infra_domains = [Street_Lighting, Traffic_Noise, Rail_Aviation_Noise, XR_Audio];
  spatial_scope = "Owl_roosts_and_hunting_territories_in_riparian_parks";
  temporal_scope = [
    {seasons=[Winter,Spring,Fall]; local_note="Nocturnal roosting and hunting."}
  ];
  risk_bands = [
    {coord_name=Noise_dBA;      min_safe=0.00; max_safe=0.35; policy=Hard_Limit},
    {coord_name=Peak_Noise_dBC; min_safe=0.00; max_safe=0.40; policy=Hard_Limit},
    {coord_name=ALAN_Lux;       min_safe=0.00; max_safe=0.30; policy=Soft_Limit_Derate}
  ];
  ecosafety_corridor_ids = ["OWLQUIETCORRIDORV1"];
  enforcement_mode = "Hard";
  notes = "Protects owl roosts from impulsive and continuous noise and excessive night lighting near riparian parks.";
}

// ---------------------------------------------------------------------
// 6. Cross-species interface contracts (humans + nonhumans)
// ---------------------------------------------------------------------

XSI_CONTRACT csi_xr_grid_humans_bats_owls {
  contract_id = "CSI-XR-GRID-HUMANS-BATS-OWLS-001";
  birth_sign  = Desert_Sonoran;
  human_neurorights = [Soma_Safety, Cognitive_Load, Emotion_Fear, Emotion_Pain, Emotion_Sanity];
  species_ids = ["homo_sapiens_human_phoenix", "bat_guild_sonoran_commuter", "bubo_virginianus_great_horned_owl"];
  infra_domains = [XR_Display, XR_Audio, XR_Haptics, Street_Lighting, Building_Facade_Lighting];
  risk_bands = [
    {coord_name=ALAN_Lux;          min_safe=0.00; max_safe=0.50; policy=Soft_Limit_Derate},
    {coord_name=ALAN_Blue_Fraction;min_safe=0.00; max_safe=0.40; policy=Soft_Limit_Derate},
    {coord_name=Noise_dBA;         min_safe=0.00; max_safe=0.60; policy=Soft_Limit_Derate}
  ];
  notes = "XR grids and lighting patterns must satisfy both human neuroright envelopes and nonhuman dark/quiet corridor needs in Sonoran settings.";
}

