// ============================================================================
// SECTION 11: UNIT TEST SPECIFICATIONS
// ============================================================================

test WaterAllocationContractTests {
    test_allocate_by_priority {
        let available_water = 10000.0
        let demands = {1: 3000.0, 2: 5000.0, 3: 4000.0}
        let priorities = {1: 1, 2: 2, 3: 3}
        
        let plans = WaterAllocationContract.allocate_by_priority(
            available_water, demands, priorities
        )
        
        assert plans.length == 3
        assert plans[0].volume_af == 3000.0 // Priority 1 gets full allocation
        assert plans[1].volume_af == 5000.0 // Priority 2 gets full allocation
        assert plans[2].volume_af == 2000.0 // Priority 3 gets remaining
    }

    test_enforce_indigenous_water_rights {
        let total = 10000.0
        let indigenous = 1500.0 // 15% of total
        
        let result = WaterAllocationContract.enforce_indigenous_water_rights(
            total, indigenous
        )
        
        assert result == true // Meets 15% minimum
    }

    test_flash_flood_emergency {
        let state = WaterCapitalState {
            flash_flood_risk: 0.85,
            ...
        }
        
        let action = WaterEmergencyProtocol.handle_flash_flood_emergency(state)
        
        assert action == NodeAction.EMERGENCY_STOP
    }

    test_water_quality_computation {
        let wqi = WaterQualityReclamationContract.compute_water_quality_index(
            7.2,  // pH (optimal)
            1.5,  // Turbidity (good)
            8.0,  // Dissolved oxygen (good)
            500.0 // Conductivity (optimal)
        )
        
        assert wqi >= 90.0 // Should meet EPA SDWA standards
    }

    test_monsoon_detection {
        let rainfall_history = [0.1, 0.6, 0.8, 0.2, 0.7]
        
        let is_monsoon = MonsoonResilienceContract.detect_monsoon_season(rainfall_history)
        
        assert is_monsoon == true // 3 events > 0.5 inches/hour
    }

    test_treaty_compliance {
        let allocations = [
            WaterAllocationPlan { allocation_type: INDIGENOUS, volume_af: 1500.0, ... },
            WaterAllocationPlan { allocation_type: MUNICIPAL, volume_af: 8500.0, ... }
        ]
        
        let result = WaterComplianceAudit.verify_indigenous_treaty_compliance(allocations)
        
        assert result == Ok(true) // 15% indigenous allocation
    }
}

