// ============================================================================
// CI/CD INTEGRATION HOOKS: Enforce Registry at Merge Gate
// ============================================================================

// Hook 1: Pre-merge validation — reject PRs proposing implemented/deprecated paths
hook PreMergeValidation(pr_files: Vec<String>) {
  for file in pr_files {
    let entry = FileRegistry.find(|e| e.path == file);
    if entry != null && (entry.status == implemented || entry.status == deprecated) {
      reject_pr else "File {file} is {entry.status} (aleId: {entry.aleId}). Use deeper path or new sequence.";
    }
  }
}

// Hook 2: Post-merge update — auto-suggest registry update when new file merged
hook PostMergeUpdate(new_file_path: String, new_content_hash: [u8; 64]) {
  let entry = FileRegistry.find_mut(|e| e.path == new_file_path && e.status == missing);
  if entry != null {
    entry.status = implemented;
    entry.content_hash = Some(new_content_hash);
    entry.updated_at = current_utc_iso8601();
    suggest_commit else "Registry auto-update: {entry.aleId} → implemented";
  }
}

// Hook 3: Treaty compliance audit — verify Indigenous-domain entries have FPIC proof
hook TreatyComplianceAudit() {
  for entry in FileRegistry {
    if (entry.domain.contains("indigenous") || entry.path.contains("GILA-RIVER") || entry.path.contains("SALT-RIVER") || entry.path.contains("PIIPAASH")) {
      assert entry.sovereignty_proof != null else "Treaty audit failure: {entry.aleId} lacks FPIC sovereignty_proof.";
    }
  }
}

// Hook 4: Neurorights audit — verify biosignal entries have explicit protection notes
rule NeurorightsAudit(e: FileRegistryEntry) {
  if (e.domain.contains("biosignal") || e.domain.contains("neural") || e.domain.contains("bci")) {
    assert e.notes != null && e.notes.contains("neurorights") else "Neurorights audit failure: {e.aleId} lacks explicit neurorights capsule in notes.";
  }
}

// ============================================================================
// OFFLINE CAPABILITY: Local-First Registry Sync Protocol
// ============================================================================

protocol OfflineRegistrySync {
  // When offline, generators read local registry snapshot
  field local_snapshot_path: String = ".aletheion/registry_snapshot.aln";

  // On reconnect, merge local changes with authoritative registry
  function sync_with_authority(authority_url: String) -> Result<(), RegistrySyncError> {
    // 1. Fetch authoritative registry (PQ-signed)
    // 2. Validate sovereignty_proof signatures
    // 3. Merge local "missing→implemented" transitions
    // 4. Reject conflicts via UniqueAleId rule
    // 5. Update local_snapshot_path atomically
  }

  // Buffer new file proposals during offline; replay on reconnect
  function buffer_proposal(proposal: FileRegistryEntry) -> Result<(), OfflineBufferError> {
    assert proposal.status == missing else "Offline proposals may only target missing entries.";
    // Append to .aletheion/offline_proposals.jsonl with PQ signature
  }
}

// ============================================================================
// DOCUMENTATION: Usage Guide for Assistants & Generators
// ============================================================================

/*
ALETHEION FILE REGISTRY USAGE CONTRACT
======================================

FOR ASSISTANTS / CODE GENERATORS:
1. BEFORE proposing ANY new file:
   a. Read this registry file (aletheion/tools/registry/ALE-TOOL-FILE-REGISTRY-001.aln)
   b. Filter entries where status == "missing" OR status == "planned"
   c. Select target with matching domain + unblocked path
   d. Generate code ONLY for that aleId/path
   e. After generation, update registry: status → implemented, add content_hash

2. NEVER propose:
   - Any entry with status == implemented or deprecated
   - Any path already in registry (even with new aleId)
   - Any aleId already in registry (even with new path)

3. For variants of existing functionality:
   - Use new sequence: -002, -003, etc.
   - Use deeper directory: e.g., .../v2/, .../experimental/
   - Document relationship in notes: "Variant of ALE-* -001; extends X, deprecates Y"

4. Treaty-compliant domains (indigenous, treaty, GILA-RIVER, SALT-RIVER, PIIPAASH):
   - MUST include sovereignty_proof field with valid FPIC capsule
   - MUST include notes referencing specific tribal consultation

5. Neurorights-protected domains (biosignal, neural, bci):
   - MUST include "neurorights" in notes field
   - MUST NOT propose subliminal stimuli, manipulative timing, or forced consent patterns

FOR HUMAN MAINTAINERS:
- When merging a new file to main branch:
  1. Compute PQ-secure content hash (e.g., ALN-Blake3-PQ)
  2. Update registry entry: status=implemented, content_hash=<hash>, updated_at=<UTC>
  3. Add sovereignty_proof if indigenous domain
  4. Run CI: `aletheion-ci validate-registry`

- When deprecating a file:
  1. Set status=deprecated
  2. Add notes: "Deprecated by ALE-* -002; migration guide: <link>"
  3. Do NOT delete entry — preserves historical audit trail

EMERGENCY OVERRIDE:
- In genuine emergency (system compromise, safety threat), authorized signers may:
  1. Temporarily set status=missing for critical path
  2. Generate override file with aleId suffix "-EMERGENCY"
  3. Post-emergency: deprecate emergency file, restore original status
  4. All overrides logged to immutable audit ledger (see ALE-SEC-MOBILITY-OVERRIDE-181)

*/

