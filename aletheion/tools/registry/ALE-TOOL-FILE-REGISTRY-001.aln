// aletheion/tools/registry/ALE-TOOL-FILE-REGISTRY-001.aln
// Canonical registry of "already-implemented" files for Aletheion.
// Purpose:
// - Give assistants, codegen tools, and CI a single source of truth
//   about which deep-path files EXIST and MUST NOT be proposed again.
// - Force proposal engines to emit only NEW paths / NEW IDs.
//
// Usage contract (for assistants / generators):
// 1. Before proposing any new file, read FileRegistryEntry where status == "implemented".
// 2. DO NOT propose a file with the same `path` OR the same `aleId` again.
// 3. If a new variant is needed, use a new suffix: -002, -003 and a deeper directory.
// 4. Only entries with status "planned" or "missing" are eligible for codegen suggestions.

schema FileRegistryEntry {
  // Globally unique Aletheion logical ID, e.g. "ALE-GOV-BIRTH-SIGN-MODEL-001".
  field aleId       : String;

  // Exact repository path, relative to repo root.
  field path        : String;

  // Status of this file in the monorepo.
  // "implemented"  : file exists and is wired into workflows.
  // "planned"      : reserved ID/path; future implementation only.
  // "deprecated"   : must not be reintroduced; replaced by another ID.
  // "missing"      : allowed to be proposed exactly ONCE, then must flip to implemented/planned.
  field status      : Enum<FileStatus>;

  // High-level domain tag to help generators pick alternatives.
  field domain      : String;   // e.g., "water", "thermal", "governance", "trust", "birthsigns"

  // Optional free-text notes for humans / tools.
  field notes       : Optional<String>;
}

enum FileStatus {
  implemented;
  planned;
  deprecated;
  missing;
}

// ---------------------------
// Seed entries (examples)
// Add / edit here whenever you actually create a file in Git.
// ---------------------------

registry FileRegistryEntry[] FileRegistry = [

  // Governance: Birth-Signs core model (already generated by assistant once)
  {
    aleId   : "ALE-GOV-BIRTH-SIGN-MODEL-001",
    path    : "aletheion/governance/birthsigns/ALE-GOV-BIRTH-SIGN-MODEL-001.rs",
    status  : implemented,
    domain  : "governance.birthsigns",
    notes   : "Core Birth-Sign types and bindings; do NOT propose this again. Any future revision must use ALE-GOV-BIRTH-SIGN-MODEL-002 with a deeper path."
  },

  // Governance: Birth-Sign propagation glue (Lua)
  {
    aleId   : "ALE-GOV-BIRTH-SIGN-PROPAGATION-001",
    path    : "aletheion/governance/birthsigns/ALE-GOV-BIRTH-SIGN-PROPAGATION-001.lua",
    status  : implemented,
    domain  : "governance.birthsigns",
    notes   : "Jurisdictional signature propagation S1–S5; future variants must use ...-002 or deeper subdirs."
  },

  // Trust: governed decision envelope
  {
    aleId   : "ALE-TRUST-GOVERNED-DECISION-TX-001",
    path    : "aletheion/trust/schemas/ALE-TRUST-GOVERNED-DECISION-TX-001.aln",
    status  : implemented,
    domain  : "trust.provenance",
    notes   : "Canonical Googolswarm envelope; MUST NOT be re-suggested."
  },

  // ERM: canonical workflow pattern
  {
    aleId   : "ALE-ERM-WORKFLOW-PATTERN-001",
    path    : "aletheion/erm/workflows/ALE-ERM-WORKFLOW-PATTERN-001.aln",
    status  : implemented,
    domain  : "erm.pattern",
    notes   : "Seven-stage workflow skeleton; generators must reuse, not recreate."
  },

  // CI: governance preflight
  {
    aleId   : "ALE-CI-GOVERNANCE-PREFLIGHT-001",
    path    : ".github/workflows/aletheion-governance-schema-preflight-001.yml",
    status  : implemented,
    domain  : "ci.compliance",
    notes   : "GitHub Actions job for ALN/WorkflowPattern; no duplicate CI with same role."
  },

  // Example: water ingestion backbone (if/when you add it)
  {
    aleId   : "ALE-RM-WATER-INGESTION-001",
    path    : "aletheion/rm/water/ALE-RM-WATER-INGESTION-001.rs",
    status  : planned,
    domain  : "water.ingestion",
    notes   : "Reserved. Once implemented, set status=implemented to block re-suggestions."
  },

  // Example slot for future use (tools may safely propose exactly once)
  {
    aleId   : "ALE-GOV-RIGHTS-TREATY-GRAMMAR-001",
    path    : "aletheion/governance/aln/ALE-GOV-RIGHTS-TREATY-GRAMMAR-001.aln",
    status  : missing,
    domain  : "governance.aln",
    notes   : "Safe target for the NEXT governance grammar file. After creation, mark implemented."
  }
];

// ---------------------------
// Helper rules for generators (self-documenting)
// ---------------------------

// Rule: no two entries may share the same aleId.
rule UniqueAleId(e1: FileRegistryEntry, e2: FileRegistryEntry) {
  if (e1.aleId == e2.aleId) {
    assert e1.path == e2.path
      else "Duplicate aleId with different paths is forbidden; use a new ALE-* ID.";
  }
}

// Rule: generators may only target entries with status in {planned, missing}.
rule GeneratorMayTarget(e: FileRegistryEntry) {
  if (e.status == implemented or e.status == deprecated) {
    // This is a hard stop for assistants / codegen.
    assert false else "Do not generate or propose code for an implemented/deprecated file.";
  }
}
