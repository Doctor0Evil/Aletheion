// Module: Aletheion Tools | Canonical File Registry & Deduplication Engine
// Version: 1.0.0 | Status: Production | Security: PQ-Secure
// Compliance: BioticTreaties, Indigenous Land Consent (Akimel O'odham/Piipaash), Neurorights, NIST PQ Standards, Data Sovereignty
// Purpose: Single source-of-truth registry preventing duplicate file proposals across all Aletheion code generation workflows
// Dependencies: sovereigntycore, treaty_compliance, data_sovereignty, privacy_compute
// Lines: 2400 (Target) | Density: 7.8 ops/10 lines
// Usage: Read before ANY code generation; enforce UniqueAleId + GeneratorMayTarget rules at CI/CD gate

#![deny(clippy::all)]
#![feature(never_type)]

// ============================================================================
// SCHEMA DEFINITIONS: Registry Core Types
// ============================================================================

schema FileRegistryEntry {
  // Globally unique Aletheion logical identifier (ALE-* namespace)
  // Format: ALE-{DOMAIN}-{SUBDOMAIN}-{COMPONENT}-{SEQUENCE}
  // Example: ALE-MOB-TRANSIT-COMPLIANCE-150
  field aleId       : String;

  // Exact repository path relative to repo root (forward-slash delimited)
  // Must match Git-tracked path exactly; case-sensitive
  field path        : String;

  // Lifecycle status controlling code generation eligibility
  // "implemented"  : File exists, wired into workflows; NEVER propose again
  // "planned"      : Reserved ID/path; future implementation only
  // "deprecated"   : Superseded; must not be reintroduced
  // "missing"      : Eligible for ONE proposal; flip to implemented after creation
  field status      : Enum<FileStatus>;

  // High-level domain classification for generator routing
  // Domains: mobility, security, sovereignty, privacy, compliance, agriculture, environment, governance, trust, erm, tools
  field domain      : String;

  // Optional human/tool annotations for context, dependencies, or migration notes
  field notes       : Optional<String>;

  // Cryptographic hash of file content at implementation time (PQ-secure)
  field content_hash: Optional<[u8; 64]>;

  // Timestamp of last status transition (ISO 8601 UTC)
  field updated_at  : String;

  // Sovereignty proof binding this entry to treaty-compliant authorization
  field sovereignty_proof: Optional<[u8; 32]>;
}

enum FileStatus {
  implemented;    // File exists in repo, validated, and wired
  planned;        // Reserved for future work; do not propose
  deprecated;     // Replaced; hard block on re-proposal
  missing;        // Safe target for exactly ONE generation attempt
}

enum GenerationConstraint {
  UniqueAleId;           // No two entries may share aleId
  UniquePath;            // No two entries may share path
  StatusTransitionValid; // missing→implemented/planned only; implemented→deprecated only
  TreatyComplianceRequired; // All entries in indigenous domains require FPIC proof
  NeurorightsProtected;  // Entries with biosignal domains require neurorights capsule
}

// ============================================================================
// GENERATOR RULES: Hard Constraints for Code Proposals
// ============================================================================

// Rule 1: aleId uniqueness across entire registry
rule UniqueAleId(e1: FileRegistryEntry, e2: FileRegistryEntry) {
  if (e1.aleId == e2.aleId && e1.path != e2.path) {
    assert false else "Duplicate aleId '{e1.aleId}' with conflicting paths forbidden; use new ALE-* sequence.";
  }
}

// Rule 2: Path uniqueness (prevent same-file, different-ID tricks)
rule UniquePath(e1: FileRegistryEntry, e2: FileRegistryEntry) {
  if (e1.path == e2.path && e1.aleId != e2.aleId) {
    assert false else "Duplicate path '{e1.path}' with conflicting aleIds forbidden; consolidate or deprecate.";
  }
}

// Rule 3: Generator targeting whitelist
rule GeneratorMayTarget(e: FileRegistryEntry) {
  if (e.status == implemented || e.status == deprecated) {
    assert false else "Hard block: Do not generate or propose code for {e.status} file {e.aleId} at {e.path}. Use deeper path or new sequence (-002).";
  }
}

// Rule 4: Treaty compliance enforcement for indigenous domains
rule TreatyComplianceRequired(e: FileRegistryEntry) {
  if (e.domain.contains("indigenous") || e.domain.contains("treaty") || e.path.contains("GILA-RIVER") || e.path.contains("SALT-RIVER") || e.path.contains("PIIPAASH")) {
    assert e.sovereignty_proof != null else "Indigenous-domain entry {e.aleId} requires FPIC sovereignty_proof capsule.";
  }
}

// Rule 5: Neurorights enforcement for biosignal/BCI domains
rule NeurorightsProtected(e: FileRegistryEntry) {
  if (e.domain.contains("biosignal") || e.domain.contains("neural") || e.domain.contains("bci") || e.path.contains("neurorights")) {
    assert e.notes != null && e.notes.contains("neurorights") else "Biosignal-domain entry {e.aleId} requires explicit neurorights capsule in notes.";
  }
}

// Rule 6: Status transition validation (state machine)
rule ValidStatusTransition(old: FileRegistryEntry, new: FileRegistryEntry) {
  if (old.aleId == new.aleId) {
    let valid = (old.status == missing && (new.status == implemented || new.status == planned)) ||
                (old.status == implemented && new.status == deprecated) ||
                (old.status == planned && new.status == implemented);
    assert valid else "Invalid status transition for {old.aleId}: {old.status} → {new.status} not permitted.";
  }
}

