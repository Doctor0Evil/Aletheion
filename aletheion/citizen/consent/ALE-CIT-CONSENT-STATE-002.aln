    enabled: true
    retention_days: 2555
    encryption: "XChaCha20-Poly1305"
    access_control: "stake_multisig_verified"
    export_format: "JSONL"
    citation: "7-year audit retention for consent compliance"
}

@compliance_verification {
    enabled: true
    verification_tools: ["ALE-COMPLIANCE-IFC-NEURORIGHTS-001.rs", "ALE-LEX-MICROTREATY-COMPILER-CORE-002.rs"]
    ci_integration: true
    preflight_required: true
    citation: "Compliance preflight per Aletheion CI/CD standards"
}
