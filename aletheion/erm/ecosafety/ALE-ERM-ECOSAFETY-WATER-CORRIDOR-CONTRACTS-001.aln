// ============================================================================
// SECTION 1: RISK COORDINATE ATOMS (Instantiated Bounds)
// ============================================================================
// These atoms instantiate the RiskCoordId types from Rust with concrete
// numerical bounds validated against 2026 Phoenix research data.
// All values are normalized rx ∈ [0,1] unless specified otherwise.
// ============================================================================

ATOM RiskCoordAtom PFAS_CONCENTRATION {
    id: "PFAS";
    domain: WATER;
    unit: "ng/L_normalized";
    minsafe: 0.0;
    maxsafe: 0.7;          // EPA HAL 4ng/L normalized to 0.7 safety margin
    soft_boundary: 0.5;    // Derate trigger at 50% of max
    measurement_method: "LCMS_2026_PROTOCOL";
    pq_signature: "DILITHIUM_5_VERIFIED";
};

ATOM RiskCoordAtom NUTRIENT_LOAD {
    id: "Nutrient";
    domain: WATER;
    unit: "mg_L_normalized";
    minsafe: 0.1;          // Minimum for biotic health
    maxsafe: 0.8;          // Eutrophication threshold
    soft_boundary: 0.6;
    measurement_method: "OPTICAL_SENSOR_NITRATE";
    pq_signature: "DILITHIUM_5_VERIFIED";
};

ATOM RiskCoordAtom HYDRAULIC_HEAD {
    id: "HydraulicHead";
    domain: MAR;
    unit: "meters_normalized";
    minsafe: 0.2;          // Minimum aquifer pressure
    maxsafe: 0.9;          // Surcharge risk threshold
    soft_boundary: 0.75;
    measurement_method: "PRESSURE_TRANSDUCER_CALIBRATED";
    pq_signature: "DILITHIUM_5_VERIFIED";
};

ATOM RiskCoordAtom WATER_TEMPERATURE {
    id: "Temp";
    domain: THERMAL;
    unit: "celsius_normalized";
    minsafe: 0.1;          // Freeze protection
    maxsafe: 0.85;         // Thermal shock threshold (35°C normalized)
    soft_boundary: 0.7;
    measurement_method: "THERMISTOR_ARRAY";
    pq_signature: "DILITHIUM_5_VERIFIED";
};

ATOM RiskCoordAtom DISSOLVED_OXYGEN {
    id: "DissolvedOxygen";
    domain: BIOTIC;
    unit: "mg_L_normalized";
    minsafe: 0.3;          // Hypoxia threshold (normalized inverse)
    maxsafe: 1.0;
    soft_boundary: 0.4;    // Derate if approaching hypoxia
    measurement_method: "OPTICAL_DO_SENSOR";
    pq_signature: "DILITHIUM_5_VERIFIED";
};

ATOM RiskCoordAtom BED_SHEAR_STRESS {
    id: "Shear";
    domain: CANAL;
    unit: "Pa_normalized";
    minsafe: 0.0;
    maxsafe: 0.6;          // Erosion threshold
    soft_boundary: 0.45;
    measurement_method: "ADCP_DERIVED";
    pq_signature: "DILITHIUM_5_VERIFIED";
};

// ============================================================================
