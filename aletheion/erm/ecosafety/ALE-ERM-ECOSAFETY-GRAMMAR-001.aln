# ALE-ERM-ECOSAFETY-GRAMMAR-001.aln
# Aletheion ERM Ecosafety Grammar Spine
# Location: aletheion/erm/ecosafety/ALE-ERM-ECOSAFETY-GRAMMAR-001.aln
# Purpose: Canonical ALN grammar for ecosafety risk coordinates rx, Lyapunov residual V_t,
#          and corridor policies enforcing "no corridor, no build" and
#          "violated corridor → derate/stop" across all ecosafety-governed modules,
#          with explicit specialization for biodegradable cyboquatic nodes in DowntownCentral Phoenix.

namespace ALE.ERM.ECOSAFETY.GRAMMAR.001

############################################################
# 1. Core scalar types
############################################################

atom RiskName
  doc "Identifier for a normalized risk coordinate rx in [0,1], e.g. PFAS, Temp, r_degrade, r_tox_acute."
  field id : string

atom DomainName
  doc "Functional domain governed by ecosafety corridors."
  enum
    WATER
    AIR
    BIOCHAR
    SOFT_ROBOT
    MAR
    WETLAND
    MATERIAL
    NEUROBIOME
    THERMAL
    DOWNTOWN_DRAINAGE   # corridor-wide eco/thermal operations
    DOWNTOWN_CYBO       # DowntownCentral cyboquatic nodes

atom TestProtocolId
  doc "Reference to a standardized test method used to derive risk coordinates, e.g. ISO 14851, OECD 201, LCMS assay ID."
  field id : string

atom MaterialId
  doc "Identifier for a material or material stack; for biodegradable nodes this refers to a specific substrate or composite."
  field id : string

atom NodeId
  doc "Identifier for a cyboquatic node or ecosafety-governed asset."
  field id : string

atom CorridorId
  doc "Identifier for a corridor definition, unique within a domain."
  field id : string

atom SystemId
  doc "Identifier for a dynamical system for which a Lyapunov residual V_t is computed."
  field id : string

atom ShardId
  doc "Identifier for a simulator / experiment shard, e.g. decomposition.sim, qpudata.shard."
  field id : string

atom GeographyId
  doc "Geographic binding for ecosafety context, e.g. REGION_DOWNTOWN_CORE."
  field id : string

############################################################
# 2. Risk coordinate and vector definitions
############################################################

atom RiskCoordAtom
  doc "Normalized risk coordinate rx ∈ [0,1] with safe band and test provenance."
  field name        : RiskName
  field value_min   : float    # inclusive lower bound of allowed rx
  field value_max   : float    # inclusive upper bound of allowed rx
  field proto_ref   : TestProtocolId
  field shard_refs  : list ShardId

atom RiskVectorAtom
  doc "Named bundle of risk coordinates for a corridor or system."
  field id          : string
  field domain      : DomainName
  field coords      : list RiskCoordAtom

############################################################
# 3. Lyapunov residual V_t specification
############################################################

atom LyapunovResidualSpec
  doc "Specification of Lyapunov residual V_t for a governed system."
  field system      : SystemId
  field vt_min      : float      # minimum acceptable V_t
  field vt_max      : float      # maximum acceptable V_t
  field monotone    : bool       # if true, V_t must be non-increasing
  field tolerance   : float      # allowed numerical slack on monotonicity

############################################################
# 4. Corridor and node ecosafety declarations
############################################################

atom CorridorAtom
  doc "Ecosafety corridor for a domain, defined as a RiskVector and optional Lyapunov spec."
  field corridor_id : CorridorId
  field domain      : DomainName
  field geography   : GeographyId
  field vector      : RiskVectorAtom
  field lyapunov    : optional LyapunovResidualSpec

atom NodeEcosafetyAtom
  doc "Ecosafety declaration for a node; must reference at least one CorridorAtom."
  field node_id     : NodeId
  field domain      : DomainName
  field geography   : GeographyId
  field corridors   : list CorridorId

############################################################
# 5. Policy atoms for decision outcomes
############################################################

atom EcosafetyPolicyAtom
  doc "Policy for handling ecosafety corridor evaluation outcomes."
  field domain        : DomainName
  field on_satisfied  : string   # e.g. 'allow'
  field on_soft_violation : string   # e.g. 'derate'
  field on_hard_violation : string   # e.g. 'stop'

atom EvaluationStatusAtom
  doc "Summarized evaluation status for a corridor at a decision tick."
  enum
    SATISFIED
    SOFT_VIOLATION
    HARD_VIOLATION

atom NodeActionAtom
  doc "Resulting high-level action decision for a node under ecosafety evaluation."
  enum
    ALLOW
    DERATE
    STOP

############################################################
# 6. Biodegradable-material-specific rx library
############################################################

# 6.1 Canonical risk names for biodegradable cyboquatic nodes

const RISK_NAME_R_DEGRADE         : RiskName = { id = "r_degrade" }
const RISK_NAME_R_RESIDUAL_MASS   : RiskName = { id = "r_residual_mass" }
const RISK_NAME_R_MICROPLASTICS   : RiskName = { id = "r_microplastics" }
const RISK_NAME_R_TOX_ACUTE       : RiskName = { id = "r_tox_acute" }
const RISK_NAME_R_TOX_CHRONIC     : RiskName = { id = "r_tox_chronic" }

# 6.2 Canonical protocol identifiers (non-exhaustive; extend as new assays are adopted)

const PROTO_ISO_14851          : TestProtocolId = { id = "ISO_14851_AEROBIC_BIODEGRADATION" }
const PROTO_OECD_201           : TestProtocolId = { id = "OECD_201_ALGAE_INHIBITION" }
const PROTO_OECD_202           : TestProtocolId = { id = "OECD_202_DAPHNIA_ACUTE" }
const PROTO_LCMS_LEACHATE_STD1 : TestProtocolId = { id = "LCMS_LEACHATE_STD1" }

# 6.3 Template corridor for biodegradable soft-robotic materials at lab-validated band

# NOTE: These bands are normalized rx ∈ [0,1]; calibration is handled in Rust by
# mapping ISO/OECD/LCMS outputs into this scale. Here we only encode the allowed
# interior for deployment.

template BiodegradableMaterialRiskVector
  arg material : MaterialId
  returns RiskVectorAtom
  body {
    id     = "BIO_" ++ material.id
    domain = SOFT_ROBOT
    coords = [
      { name = RISK_NAME_R_DEGRADE
      , value_min = 0.40    # minimum acceptable normalized degradation fraction over study horizon
      , value_max = 0.95
      , proto_ref = PROTO_ISO_14851
      , shard_refs = []     # populated with decomposition.sim shard IDs in deployment
      },
      { name = RISK_NAME_R_RESIDUAL_MASS
      , value_min = 0.00
      , value_max = 0.20    # at most 20% residual mass at horizon
      , proto_ref = PROTO_ISO_14851
      , shard_refs = []
      },
      { name = RISK_NAME_R_MICROPLASTICS
      , value_min = 0.00
      , value_max = 0.10    # microplastics risk kept low
      , proto_ref = PROTO_LCMS_LEACHATE_STD1
      , shard_refs = []
      },
      { name = RISK_NAME_R_TOX_ACUTE
      , value_min = 0.00
      , value_max = 0.10    # acute toxicity band (normalized from OECD 201/202)
      , proto_ref = PROTO_OECD_202
      , shard_refs = []
      },
      { name = RISK_NAME_R_TOX_CHRONIC
      , value_min = 0.00
      , value_max = 0.15    # chronic toxicity band
      , proto_ref = PROTO_OECD_201
      , shard_refs = []
      }
    ]
  }

template BiodegradableMaterialCorridor
  arg material   : MaterialId
  arg geography  : GeographyId
  returns CorridorAtom
  body {
    corridor_id = { id = "CORRIDOR_BIO_" ++ material.id }
    domain      = SOFT_ROBOT
    geography   = geography
    vector      = BiodegradableMaterialRiskVector(material)
    lyapunov    = some {
      system   = { id = "SYSTEM_BIO_NODE_" ++ material.id }
      vt_min   = 0.0
      vt_max   = 1.0
      monotone = true        # require non-increasing V_t for biodegradable nodes
      tolerance = 1e-3
    }
  }

############################################################
# 7. DowntownCentral corridor examples
############################################################

# DowntownCentral Phoenix geography identifiers (must match ERM/region files)
const GEO_DOWNTOWN_CORE       : GeographyId = { id = "REGION_DOWNTOWN_CORE" }
const GEO_DOWNTOWN_CANAL_EDGE : GeographyId = { id = "REGION_DOWNTOWN_CANAL_EDGE" }

# Example biodegradable material IDs used in DowntownCentral prototypes
const MAT_FLOWVAC_SUBSTRATE_V1 : MaterialId = { id = "FLOWVAC_SUBSTRATE_V1" }
const MAT_SOFTBOT_SHELL_V1     : MaterialId = { id = "SOFTBOT_SHELL_V1" }

const CORRIDOR_BIO_FLOWVAC_DTC : CorridorAtom =
  BiodegradableMaterialCorridor(MAT_FLOWVAC_SUBSTRATE_V1, GEO_DOWNTOWN_CANAL_EDGE)

const CORRIDOR_BIO_SHELL_DTC : CorridorAtom =
  BiodegradableMaterialCorridor(MAT_SOFTBOT_SHELL_V1, GEO_DOWNTOWN_CORE)

# Example node ecosafety bindings for DowntownCentral cyboquatic biodegradable nodes

const NODE_DTC_CYBO_SOFTBOT_01 : NodeEcosafetyAtom = {
  node_id   = { id = "DTC_CYBO_SOFTBOT_01" }
  domain    = SOFT_ROBOT
  geography = GEO_DOWNTOWN_CANAL_EDGE
  corridors = [ CORRIDOR_BIO_FLOWVAC_DTC.corridor_id ]
}

const NODE_DTC_CYBO_SOFTBOT_02 : NodeEcosafetyAtom = {
  node_id   = { id = "DTC_CYBO_SOFTBOT_02" }
  domain    = SOFT_ROBOT
  geography = GEO_DOWNTOWN_CORE
  corridors = [ CORRIDOR_BIO_SHELL_DTC.corridor_id ]
}

############################################################
# 8. Core ecosafety rules
############################################################

# 8.1 No corridor, no build

rule ecosafety_corridor_required
  doc "Any ecosafety-governed module in specified domains must declare at least one CorridorAtom."
  when
    module.domain in [WATER, AIR, BIOCHAR, SOFT_ROBOT, MAR, WETLAND, MATERIAL]
  then
    require exists c : CorridorAtom where c.domain == module.domain
      else error "ECOSAFETY:NO_CORRIDOR_NO_BUILD: domain=" ++ to_string(module.domain)

# 8.2 Node must reference at least one corridor

rule ecosafety_node_must_have_corridor
  doc "Every NodeEcosafetyAtom must reference at least one corridor."
  when
    n : NodeEcosafetyAtom
  then
    require size(n.corridors) > 0
      else error "ECOSAFETY:NODE_WITHOUT_CORRIDOR: node=" ++ n.node_id.id

# 8.3 Policy: map evaluation status → node action

const POLICY_DEFAULT : EcosafetyPolicyAtom = {
  domain            = WATER
  on_satisfied      = "allow"
  on_soft_violation = "derate"
  on_hard_violation = "stop"
}

const POLICY_SOFT_ROBOT : EcosafetyPolicyAtom = {
  domain            = SOFT_ROBOT
  on_satisfied      = "allow"
  on_soft_violation = "derate"
  on_hard_violation = "stop"
}

template DecideNodeAction
  arg policy : EcosafetyPolicyAtom
  arg status : EvaluationStatusAtom
  returns NodeActionAtom
  body {
    match status with
      SATISFIED      -> ALLOW
      SOFT_VIOLATION -> DERATE
      HARD_VIOLATION -> STOP
  }

# 8.4 Lyapunov residual invariants

rule ecosafety_lyapunov_monotone
  doc "If a LyapunovResidualSpec is marked monotone, enforce non-increasing V_t within tolerance."
  when
    spec : LyapunovResidualSpec
    spec.monotone == true
    history : list float = get_Vt_history(spec.system)   # provided by Rust side
  then
    require non_increasing(history, spec.tolerance)
      else error "ECOSAFETY:VT_MONOTONE_VIOLATION: system=" ++ spec.system.id

############################################################
# 9. SMART-chain / CI integration hooks
############################################################

# 9.1 SMART-chain: ecosafety check must pass before actuation in PQSTRICT chains

atom SmartChainDomain
  enum
    SMART01_AWP_THERMAL_THERMAPHORA
    SMART03_SYNTHEXIS_LNP_ENV
    SMART04_NEUROBIOME_MESH
    SMART05_SOMAPLEX_ROUTING
    SMART06_CYBOQUATIC_MAR_WETLAND

atom SmartChainMode
  enum
    CLASSICAL
    HYBRID
    PQSTRICT

atom SmartChainContext
  field chain_domain : SmartChainDomain
  field mode         : SmartChainMode

rule ecosafety_required_for_pqstrict
  doc "In PQSTRICT chains, ecosafety corridors and Lyapunov invariants must be validated before actuation."
  when
    ctx : SmartChainContext
    ctx.mode == PQSTRICT
  then
    require all_nodes_have_corridors()
      else error "ECOSAFETY:PQSTRICT_NODE_MISSING_CORRIDOR"
    require all_lyapunov_specs_satisfied()
      else error "ECOSAFETY:PQSTRICT_LYAPUNOV_VIOLATION"

# 9.2 CI preflight expectation (enforced by ecosafety-grammar-preflight.yml)

atom PreflightCheckRequest
  field checked_paths : list string

atom PreflightCheckResult
  field ok         : bool
  field violations : list string

rule ecosafety_preflight
  doc "Preflight: fail if any node in checked paths lacks corridors or if any example scenario produces a HARD_VIOLATION without STOP."
  when
    req : PreflightCheckRequest
  then
    let result = run_ecosafety_examples(req.checked_paths)
    require result.ok == true
      else error "ECOSAFETY:PREFLIGHT_FAILED: " ++ join(result.violations, "; ")

############################################################
# 10. Helper predicates (semantic, implemented in Rust)
############################################################

# The following names are reserved for Rust implementations:
# - get_Vt_history(system : SystemId) -> list float
# - non_increasing(values : list float, tol : float) -> bool
# - all_nodes_have_corridors() -> bool
# - all_lyapunov_specs_satisfied() -> bool
# - run_ecosafety_examples(paths : list string) -> PreflightCheckResult

end namespace
