# -------------------------------------------------------------------
# 2. Ecosafety Corridor Bindings (Highway-Management Hooks)
# -------------------------------------------------------------------

# Each pattern family must use these standard hooks; CI will enforce presence.

record HighwayBinding {
  pattern_id                  : Id.PatternId,
  pre_optimization_validator  : string,  # function name for input corridor validation
  post_optimization_validator : string,  # function name for output corridor validation
  recycling_policy            : string   # symbolic policy name implemented in ecosafety spine
}

erm.pattern_index.highway_bindings = [
  HighwayBinding {
    pattern_id                  = "NEIGHBORHOOD_WATER",
    pre_optimization_validator  = "corridorValidateInputs_NeighborhoodWater",
    post_optimization_validator = "corridorValidateOutputs_NeighborhoodWater",
    recycling_policy            = "RecyclePlanWithStateRefresh_ThenFallback"
  },
  HighwayBinding {
    pattern_id                  = "CORRIDOR_WATER",
    pre_optimization_validator  = "corridorValidateInputs_CorridorWater",
    post_optimization_validator = "corridorValidateOutputs_CorridorWater",
    recycling_policy            = "RecyclePlanWithFallbackRouting"
  },
  HighwayBinding {
    pattern_id                  = "NEIGHBORHOOD_WASTE",
    pre_optimization_validator  = "corridorValidateInputs_NeighborhoodWaste",
    post_optimization_validator = "corridorValidateOutputs_NeighborhoodWaste",
    recycling_policy            = "RecycleToSaferSoilOrNoOpWithAlert"
  },
  HighwayBinding {
    pattern_id                  = "CORRIDOR_WASTE",
    pre_optimization_validator  = "corridorValidateInputs_CorridorWaste",
    post_optimization_validator = "corridorValidateOutputs_CorridorWaste",
    recycling_policy            = "ImmediateRerouteAwayFromNoGo"
  },
  HighwayBinding {
    pattern_id                  = "NEIGHBORHOOD_NEUROBIOME",
    pre_optimization_validator  = "corridorValidateInputs_NeighborhoodNeurobiome",
    post_optimization_validator = "corridorValidateOutputs_NeighborhoodNeurobiome",
    recycling_policy            = "ReduceCleaningIntensityAndReplan"
  },
  HighwayBinding {
    pattern_id                  = "CORRIDOR_NEUROBIOME",
    pre_optimization_validator  = "corridorValidateInputs_CorridorNeurobiome",
    post_optimization_validator = "corridorValidateOutputs_CorridorNeurobiome",
    recycling_policy            = "SwitchToMicrobiomeSafeProtocols"
  },
  HighwayBinding {
    pattern_id                  = "NEIGHBORHOOD_SOMAPLEX",
    pre_optimization_validator  = "corridorValidateInputs_NeighborhoodSomaplex",
    post_optimization_validator = "corridorValidateOutputs_NeighborhoodSomaplex",
    recycling_policy            = "RerouteToLowerJointLoadPaths"
  },
  HighwayBinding {
    pattern_id                  = "CORRIDOR_SOMAPLEX",
    pre_optimization_validator  = "corridorValidateInputs_CorridorSomaplex",
    post_optimization_validator = "corridorValidateOutputs_CorridorSomaplex",
    recycling_policy            = "DelayOrReassignRoutes"
  },
  HighwayBinding {
    pattern_id                  = "NEIGHBORHOOD_SYNTHEXIS",
    pre_optimization_validator  = "corridorValidateInputs_NeighborhoodSynthexis",
    post_optimization_validator = "corridorValidateOutputs_NeighborhoodSynthexis",
    recycling_policy            = "SuppressDisruptiveActivities"
  },
  HighwayBinding {
    pattern_id                  = "CORRIDOR_SYNTHEXIS",
    pre_optimization_validator  = "corridorValidateInputs_CorridorSynthexis",
    post_optimization_validator = "corridorValidateOutputs_CorridorSynthexis",
    recycling_policy            = "FallbackToHabitatSafeBaseline"
  },
  HighwayBinding {
    pattern_id                  = "NEIGHBORHOOD_LEXETHOS",
    pre_optimization_validator  = "corridorValidateInputs_NeighborhoodLexEthos",
    post_optimization_validator = "corridorValidateOutputs_NeighborhoodLexEthos",
    recycling_policy            = "DoNotDeployConflictingTreaties"
  },
  HighwayBinding {
    pattern_id                  = "CORRIDOR_LEXETHOS",
    pre_optimization_validator  = "corridorValidateInputs_CorridorLexEthos",
    post_optimization_validator = "corridorValidateOutputs_CorridorLexEthos",
    recycling_policy            = "DeferToHigherLevelTreaty"
  }
]

# -------------------------------------------------------------------
# 3. CI / Charter Binding Hints (for .github/workflows/compliance-preflight.yml)
# -------------------------------------------------------------------

# CI MUST:
# - Parse this file.
# - For each new or modified file, require:
#   - exactly one pattern_id declaration in its header.
#   - that its declared tier (State/Service/Gate) matches one entry in erm.pattern_index.families.
#   - that required corridors, SMART chains, and grammars are referenced.
#   - that SevenCapitalState is in the signature (where require_sevencapital_state_input = true).
#   - that governance wrappers exist for Service-tier functions.
# - Fail fast on violations (no corridor, no build).

erm.pattern_index.ci.preflight_workflow = ".github/workflows/compliance-preflight.yml"
erm.pattern_index.ci.required_header_keys = [
  "ALE_PATTERN_ID",
  "ALE_TIER",
  "ALE_DOMAIN",
  "ALE_SCALE"
]

erm.pattern_index.ci.state_tier_signature_suffix   = "State"     # e.g., neighborhoodWaterSystemState(...)
erm.pattern_index.ci.service_tier_signature_suffix = "Plan"      # e.g., neighborhoodCyboquaticNodeSchedule(...)
erm.pattern_index.ci.gate_tier_signature_suffix    = "Gate"      # e.g., neighborhoodMicroTreatyGate(...)

