# Aletheion Pattern Index (State–Service–Gate + Corridor + Rights)
# File: aletheion/erm/workflow-index/ALE-ERM-PATTERN-INDEX-STATE-SERVICE-GATE-001.aln
# Charter: Aletheion Coding Charter v1 — no corridor, no build; no raw string escape; SevenCapitalState-first.

erm.pattern_index.version = "1.0.0"
erm.pattern_index.id      = "ALE-ERM-PATTERN-INDEX-STATE-SERVICE-GATE-001"
erm.pattern_index.scope   = ["Water", "Waste", "Neurobiome", "Somaplex", "Synthexis", "LexEthos"]
erm.pattern_index.scales  = ["Neighborhood", "Corridor"]
erm.pattern_index.sevencapitals = [
  "WaterCapital",
  "ThermalCapital",
  "WasteCapital",
  "BioticCapital",
  "NeurobiomeCapital",
  "SomaticCapital",
  "TreatyCapital"
]

# -------------------------------------------------------------------
# 0. Core Types and Shared Contracts
# -------------------------------------------------------------------

type Id.NeighborhoodId = string  # Stable neighborhood key, shared with SMART chains and ERM.
type Id.CorridorId     = string  # Canonical corridor ID (e.g., "CANAL_METRO_CENTER_PARKWAY").
type Id.SegmentId      = string  # Local segment within a corridor (e.g., canal reach index).
type Id.PatternId      = string  # Machine identifier for a State–Service–Gate family.
type Id.ChainId        = string  # SMART-chain identifier (e.g., "SMART-01-WATER").
type Id.CorridorDefId  = string  # Ecosafety corridor definition ID (rx, Vt, RecyclingPolicy).

type Ecosafety.RiskCoordinate.rx = float  # normalized 0.0–1.0
type Ecosafety.Stability.Vt      = float  # Lyapunov residual; semantics defined in ecosafety spine.

record SevenCapitalState {
  water      : WaterCapitalState,
  thermal    : ThermalCapitalState,
  waste      : WasteCapitalState,
  biotic     : BioticCapitalState,
  neurobiome : NeurobiomeCapitalState,
  somatic    : SomaticCapitalState,
  treaty     : TreatyCapitalState
}

record CorridorEnvelopeRef {
  corridor_ids   : list[Id.CorridorDefId],
  rx_bounds      : map[string, (float, float)],   # metric_name -> (rx_min, rx_max)
  Vt_max         : map[string, float],           # metric_name -> Vt upper bound
  recycling_mode : string                        # e.g., "RetryStateRefresh", "FallbackPlan", "NoOpWithAlert"
}

record ProvenanceRef {
  state_snapshot_id : string,   # hash or ID of the SevenCapitalState snapshot used.
  optimizer_run_id  : string,   # ID of optimization run (for Service tier).
  smart_chain_ids   : list[Id.ChainId]
}

record GovernanceViolation {
  code        : string,         # treaty, corridor, somatic, neuro, lexethos, fpip, etc.
  description : string,         # human-readable reason, kept short.
  capital     : string,         # which capital is implicated.
  chain_id    : Id.ChainId?     # optional SMART-chain context.
}

record GovernanceResult {
  is_valid      : bool,
  recycled_plan : string?,          # serialized plan pointer or plan-id; actual plan type is domain-specific.
  violations    : list[GovernanceViolation]
}

# All pattern families must respect this Charter contract:
record PatternCharterContract {
  require_sevencapital_state_input : bool,
  require_governance_wrapper       : bool,
  require_corridor_ids             : bool,
  require_smart_chains             : bool,
  forbid_raw_string_escape         : bool,
  require_ecosafety_rx_Vt          : bool,
  require_ci_preflight_binding     : bool,
  require_formal_methods           : bool
}

# -------------------------------------------------------------------
# 1. Pattern Family Declarations (by Domain & Scale)
# -------------------------------------------------------------------

record PatternFamily {
  pattern_id       : Id.PatternId,
  domain           : string,        # e.g., "Water", "Waste", "Neurobiome", "Somaplex", "Synthexis", "LexEthos"
  scale            : string,        # "Neighborhood" | "Corridor"
  state_function   : string,        # fully-qualified function name
  service_function : string,
  gate_function    : string,
  state_struct     : string,        # canonical state struct name
  plan_struct      : string,        # canonical plan/schedule struct name
  sevencapital_slice : list[string],# capitals the family owns/reads strongly
  required_corridors : list[Id.CorridorDefId],
  required_smart_chains : list[Id.ChainId],
  required_lexethos_grammars : list[string],
  required_microtreaty_gates : list[string],
  repo_anchor_state   : string,     # file path (Rust/ALN)
  repo_anchor_service : string,
  repo_anchor_gate    : string,
  charter_contract    : PatternCharterContract
}

