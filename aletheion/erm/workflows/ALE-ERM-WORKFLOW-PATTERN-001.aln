// =============================================================================
// Aletheion ERM Workflow Pattern Spine
// Canonical ALN definition of the mandatory seven-stage workflow structure
// =============================================================================
// File: ALE-ERM-WORKFLOW-PATTERN-001.aln
// Domain: Environmental Resource Management / Workflow Orchestration
// Scope:
//   - Applies to all workflows that touch land, water, air, materials, biosignals,
//     augmentation, mobility, energy, culture, or citizens.
// Governance anchors:
//   - Birth-Signs jurisdictional signatures must be present for governed domains.
//   - Compliance preflight and ecosafety grammars must be invoked before actuation.
//   - Trust-layer append using governed decision envelopes must be performed.
//   - Citizen surface and grievance loop must be wired as S7.
// Compliance: BioticTreaties, Indigenous FPIC, EJ Zones, SMART-chain
// =============================================================================

aln_version 1.0
namespace Aletheion.ERM.Workflows

import Aletheion.TreatyOS
import Aletheion.ERM.Ecosafety.Biodegrade
import Aletheion.Governance.Lexethos.Biodegrade
import Aletheion.Governance.BirthSigns.Model
import Aletheion.Trust.Schemas.GovernedDecision
import Aletheion.Compliance.Core

// ----------------------------
// Core identifiers and aliases
// ----------------------------

type WorkflowId      = string
type WorkflowVersion = string        // "major.minor.patch"
type StageId         = string        // "S1" .. "S7"
type HookId          = string
type DID             = string
type IsoTimestamp    = string
type Decimal         = number
type Int             = integer
type Bool            = boolean

// Reference atoms used by other namespaces

atom BirthSignIdRef
  field id string        // Refers to BirthSignId in ALE-GOV-BIRTH-SIGN-MODEL-001.rs

atom GovernanceDomainRef
  field name string      // Land, Water, Air, Materials, Mobility, Biosignals, etc.

atom TrustSchemaIdRef
  field id string        // e.g., "ALE-TRUST-GOVERNED-DECISION-TX-001"

atom ComplianceProfileRef
  field id string        // e.g., "ALE-COMP-CORE-001"

atom EcosafetyProfileRef
  field id string        // e.g., "ALE-ERM-ECOSAFETY-BIODEGRADE-GRAMMAR-001"

atom RightsGrammarRef
  field id string        // e.g., "ALE-GOV-RIGHTS-TREATY-GRAMMAR-001"

atom CIWorkflowRef
  field path string      // e.g., ".github/workflows/aletheion-workflow-pattern-preflight.yml"

// =============================================================================
// 1. Workflow enums
// =============================================================================

enum WorkflowDomain {
    WATER
    THERMAL
    WASTE
    AIR
    SOIL
    MOBILITY
    ENERGY
    BIOSIGNAL
    BIOTIC
    GOVERNANCE
    CULTURE
}

enum WorkflowStatus {
    DRAFT
    VALIDATED
    ACTIVE
    SUSPENDED
    DEPRECATED
}

// Canonical seven-stage spine used across Aletheion ERM
enum WorkflowStage {
    S1_EDGE_INGESTION
    S2_STATE_MODEL_UPDATE
    S3_TRUST_APPEND_SEED
    S4_OPTIMIZATION_ENGINE
    S5_TREATY_RIGHTS_ENFORCEMENT
    S6_ACTUATION_ORCHESTRATION
    S7_CITIZEN_SURFACE_AUDIT
}

enum StageStatus {
    PENDING
    IN_PROGRESS
    COMPLETED
    FAILED
    BLOCKED
    SKIPPED
}

enum HookType {
    BIRTH_SIGN_RESOLUTION
    ALN_NORM_VALIDATION
    TRUST_APPEND
    CITIZEN_SURFACE
    FPIC_VERIFICATION
    EJ_ZONE_CHECK
    BIOTIC_TREATY_CHECK
    LYAPUNOV_STABILITY_CHECK
    TOXICITY_THRESHOLD_CHECK
    CORRIDOR_INTEGRITY_CHECK
}

enum HookEnforcement {
    MANDATORY
    CONDITIONAL
    OPTIONAL
}

// =============================================================================
// 2. Stage Input/Output Contracts
// =============================================================================

record StageInputContract {
    contract_id             : string
    stage_id                : StageId
    required_fields         : [string]
    optional_fields         : [string]
    field_types             : [string]
    validation_rules        : [string]
    min_data_quality_score  : Decimal
    schema_ref              : string
}

record StageOutputContract {
    contract_id             : string
    stage_id                : StageId
    produced_fields         : [string]
    field_types             : [string]
    downstream_stages       : [StageId]
    ledger_append_required  : Bool
    citizen_visible         : Bool
    schema_ref              : string
}

// =============================================================================
// 3. Seven-Stage Workflow Spine Definition
// =============================================================================

record WorkflowStageDefinition {
    stage_id                : StageId
    stage_number            : Int
    stage_name              : string
    description             : string
    domain_applicability    : [WorkflowDomain]
    input_contract_ref      : string
    output_contract_ref     : string
    required_hooks          : [HookId]
    optional_hooks          : [HookId]
    timeout_seconds         : Int
    retry_count             : Int
    failure_action          : string
    treaty_check_required   : Bool
    ledger_append_required  : Bool
    citizen_notification    : Bool
}

// Stage 1: Edge Ingestion (L1)
record Stage1_EdgeIngestion : WorkflowStageDefinition = {
    stage_id                    = "S1_EDGE_INGESTION"
    stage_number                = 1
    stage_name                  = "Edge Ingestion"
    description                 = "Collect raw sensor and event data from edge nodes and XR-grid devices"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOSIGNAL, BIOTIC, GOVERNANCE]
    input_contract_ref          = "CONTRACT-S1-INPUT-001"
    output_contract_ref         = "CONTRACT-S1-OUTPUT-001"
    required_hooks              = ["HOOK-BIRTHSIGN-RESOLVE-001"]
    optional_hooks              = []
    timeout_seconds             = 30
    retry_count                 = 3
    failure_action              = "retry_then_alert"
    treaty_check_required       = false
    ledger_append_required      = false
    citizen_notification        = false
}

// Stage 2: State Model Update (L2)
record Stage2_StateModelUpdate : WorkflowStageDefinition = {
    stage_id                    = "S2_STATE_MODEL_UPDATE"
    stage_number                = 2
    stage_name                  = "State Model Update"
    description                 = "Update typed ERM state models with validated edge data"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOSIGNAL, BIOTIC, GOVERNANCE]
    input_contract_ref          = "CONTRACT-S2-INPUT-001"
    output_contract_ref         = "CONTRACT-S2-OUTPUT-001"
    required_hooks              = []
    optional_hooks              = []
    timeout_seconds             = 30
    retry_count                 = 2
    failure_action              = "degrade_to_last_known"
    treaty_check_required       = false
    ledger_append_required      = false
    citizen_notification        = false
}

// Stage 3: Trust Seed (L3)
record Stage3_TrustSeed : WorkflowStageDefinition = {
    stage_id                    = "S3_TRUST_APPEND_SEED"
    stage_number                = 3
    stage_name                  = "Trust Seed Append"
    description                 = "Prepare candidate governed decision envelope and hashes for Googolswarm"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOSIGNAL, BIOTIC, GOVERNANCE]
    input_contract_ref          = "CONTRACT-S3-INPUT-001"
    output_contract_ref         = "CONTRACT-S3-OUTPUT-001"
    required_hooks              = []
    optional_hooks              = []
    timeout_seconds             = 20
    retry_count                 = 1
    failure_action              = "block_and_alert"
    treaty_check_required       = false
    ledger_append_required      = false
    citizen_notification        = false
}

// Stage 4: Optimization Engine (L4)
record Stage4_OptimizationEngine : WorkflowStageDefinition = {
    stage_id                    = "S4_OPTIMIZATION_ENGINE"
    stage_number                = 4
    stage_name                  = "Optimization Engine"
    description                 = "Run multi-objective optimization and simulation for candidate actions"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOTIC]
    input_contract_ref          = "CONTRACT-S4-INPUT-001"
    output_contract_ref         = "CONTRACT-S4-OUTPUT-001"
    required_hooks              = ["HOOK-LYAPUNOV-STABILITY-001"]
    optional_hooks              = ["HOOK-TOXICITY-THRESHOLD-001"]
    timeout_seconds             = 120
    retry_count                 = 1
    failure_action              = "use_last_valid_plan"
    treaty_check_required       = false
    ledger_append_required      = false
    citizen_notification        = false
}

// Stage 5: Treaty & Rights Enforcement (L3/L4 governance)
record Stage5_TreatyRightsEnforcement : WorkflowStageDefinition = {
    stage_id                    = "S5_TREATY_RIGHTS_ENFORCEMENT"
    stage_number                = 5
    stage_name                  = "Treaty & Rights Enforcement"
    description                 = "Evaluate proposed actions against Birth-Signs, ALN norms, FPIC, EJ, and BioticTreaties"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOSIGNAL, BIOTIC, GOVERNANCE]
    input_contract_ref          = "CONTRACT-S5-INPUT-001"
    output_contract_ref         = "CONTRACT-S5-OUTPUT-001"
    required_hooks              = [
        "HOOK-BIRTHSIGN-RESOLVE-001",
        "HOOK-ALN-NORM-VALIDATION-001",
        "HOOK-FPIC-VERIFICATION-001",
        "HOOK-EJ-ZONE-CHECK-001",
        "HOOK-BIOTIC-TREATY-CHECK-001",
        "HOOK-CORRIDOR-INTEGRITY-001"
    ]
    optional_hooks              = ["HOOK-TOXICITY-THRESHOLD-001"]
    timeout_seconds             = 60
    retry_count                 = 0
    failure_action              = "block_actuation"
    treaty_check_required       = true
    ledger_append_required      = true
    citizen_notification        = true
}

// Stage 6: Actuation Orchestration (L1/L4)
record Stage6_ActuationOrchestration : WorkflowStageDefinition = {
    stage_id                    = "S6_ACTUATION_ORCHESTRATION"
    stage_number                = 6
    stage_name                  = "Actuation Orchestration"
    description                 = "Execute approved actions via signed, rate-limited actuation buses"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOTIC]
    input_contract_ref          = "CONTRACT-S6-INPUT-001"
    output_contract_ref         = "CONTRACT-S6-OUTPUT-001"
    required_hooks              = ["HOOK-TRUST-APPEND-001"]
    optional_hooks              = []
    timeout_seconds             = 300
    retry_count                 = 2
    failure_action              = "execute_compensating_action"
    treaty_check_required       = false
    ledger_append_required      = true
    citizen_notification        = true
}

// Stage 7: Citizen Surface & Audit (L5)
record Stage7_CitizenSurfaceAudit : WorkflowStageDefinition = {
    stage_id                    = "S7_CITIZEN_SURFACE_AUDIT"
    stage_number                = 7
    stage_name                  = "Citizen Surface & Audit"
    description                 = "Append governed decision transaction and present citizen-facing explanation + grievance handle"
    domain_applicability        = [WATER, THERMAL, WASTE, AIR, SOIL, MOBILITY, ENERGY, BIOSIGNAL, BIOTIC, GOVERNANCE, CULTURE]
    input_contract_ref          = "CONTRACT-S7-INPUT-001"
    output_contract_ref         = "CONTRACT-S7-OUTPUT-001"
    required_hooks              = [
        "HOOK-TRUST-APPEND-001",
        "HOOK-CITIZEN-SURFACE-001"
    ]
    optional_hooks              = []
    timeout_seconds             = 60
    retry_count                 = 3
    failure_action              = "queue_for_retry"
    treaty_check_required       = false
    ledger_append_required      = true
    citizen_notification        = true
}

// =============================================================================
// 4. Hook Definitions
// =============================================================================

record WorkflowHookDefinition {
    hook_id                 : HookId
    hook_name               : string
    hook_type               : HookType
    description             : string
    enforcement             : HookEnforcement
    applicable_stages       : [StageId]
    input_requirements      : [string]
    output_produced         : [string]
    timeout_seconds         : Int
    failure_blocks_workflow : Bool
    treaty_module_ref       : string?
    schema_ref              : string
}

// Birth-Sign Resolution Hook
record Hook_BirthSignResolution : WorkflowHookDefinition = {
    hook_id                     = "HOOK-BIRTHSIGN-RESOLVE-001"
    hook_name                   = "Birth-Sign Resolution"
    hook_type                   = BIRTH_SIGN_RESOLUTION
    description                 = "Resolve active Birth-Signs for geo-tile and attach constraint bundles"
    enforcement                 = MANDATORY
    applicable_stages           = ["S1_EDGE_INGESTION", "S5_TREATY_RIGHTS_ENFORCEMENT"]
    input_requirements          = ["geo_tile_ref", "timestamp"]
    output_produced             = ["birth_sign_id", "constraint_bundle_ids", "indigenous_territory_flag", "ej_zone_flag"]
    timeout_seconds             = 5
    failure_blocks_workflow     = true
    treaty_module_ref           = "birthsign_resolver"
    schema_ref                  = "ALE-GOV-BIRTH-SIGN-INDEX-001"
}

// ALN Norm Validation Hook
record Hook_ALNNormValidation : WorkflowHookDefinition = {
    hook_id                     = "HOOK-ALN-NORM-VALIDATION-001"
    hook_name                   = "ALN Norm Validation"
    hook_type                   = ALN_NORM_VALIDATION
    description                 = "Validate action against all applicable ALN norms and treaty atoms"
    enforcement                 = MANDATORY
    applicable_stages           = ["S5_TREATY_RIGHTS_ENFORCEMENT"]
    input_requirements          = ["proposed_action", "birth_sign_id", "action_context"]
    output_produced             = ["violated_atom_ids", "applied_norm_ids", "treaty_decision"]
    timeout_seconds             = 30
    failure_blocks_workflow     = true
    treaty_module_ref           = "treaty_engine"
    schema_ref                  = "ALE-TRUST-GOVERNED-DECISION-TX-001"
}

// Trust Append Hook
record Hook_TrustAppend : WorkflowHookDefinition = {
    hook_id                     = "HOOK-TRUST-APPEND-001"
    hook_name                   = "Trust Append"
    hook_type                   = TRUST_APPEND
    description                 = "Append governed decision transaction to Googolswarm ledger"
    enforcement                 = MANDATORY
    applicable_stages           = ["S6_ACTUATION_ORCHESTRATION", "S7_CITIZEN_SURFACE_AUDIT"]
    input_requirements          = ["governed_decision_tx", "multi_sig_attestors"]
    output_produced             = ["ledger_transaction_id", "ledger_block_height", "append_receipt"]
    timeout_seconds             = 30
    failure_blocks_workflow     = false
    treaty_module_ref           = "trust_append_core"
    schema_ref                  = "ALE-TRUST-GOVERNED-DECISION-TX-001"
}

// Citizen Surface Hook
record Hook_CitizenSurface : WorkflowHookDefinition = {
    hook_id                     = "HOOK-CITIZEN-SURFACE-001"
    hook_name                   = "Citizen Surface"
    hook_type                   = CITIZEN_SURFACE
    description                 = "Generate citizen-readable explanation, notification, and grievance reference"
    enforcement                 = MANDATORY
    applicable_stages           = ["S7_CITIZEN_SURFACE_AUDIT"]
    input_requirements          = ["treaty_decision", "actuation_result", "ledger_transaction_id"]
    output_produced             = ["citizen_explanation", "notification_record", "grievance_reference"]
    timeout_seconds             = 10
    failure_blocks_workflow     = false
    treaty_module_ref           = null
    schema_ref                  = "ALE-TRUST-GOVERNED-DECISION-TX-001"
}

