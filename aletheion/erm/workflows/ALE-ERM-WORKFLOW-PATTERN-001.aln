record Hook_BioticTreatyCheck : WorkflowHookDefinition = {
    hook_id                     = "HOOK-BIOTIC-TREATY-CHECK-001"
    hook_name                   = "Biotic Treaty Check"
    hook_type                   = BIOTIC_TREATY_CHECK
