record Hook_EJZoneCheck : WorkflowHookDefinition = {
    hook_id                     = "HOOK-EJ-ZONE-CHECK-001"
    hook_name                   = "EJ Zone Check"
    hook_type                   = EJ_ZONE_CHECK
