// Lyapunov Stability Check Hook
record Hook_LyapunovStabilityCheck : WorkflowHookDefinition = {
    hook_id                     = "HOOK-LYAPUNOV-STABILITY-001"
    hook_name                   = "Lyapunov Stability Check"
    hook_type                   = LYAPUNOV_STABILITY_CHECK
    description                 = "Verify ecological convergence and Lyapunov stability for proposed actions"
