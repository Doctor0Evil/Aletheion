        "S6_failure: execute_compensating_action",
        "S7_failure: queue_for_retry"
    ]
    ledger_append_points            = ["S5_TREATY_RIGHTS_ENFORCEMENT", "S6_ACTUATION_ORCHESTRATION", "S7_CITIZEN_SURFACE_AUDIT"]
    citizen_notification_points     = ["S5_TREATY_RIGHTS_ENFORCEMENT", "S7_CITIZEN_SURFACE_AUDIT"]
    treaty_check_points             = ["S5_TREATY_RIGHTS_ENFORCEMENT"]
    valid_from                      = "2025-01-01T00:00:00Z"
