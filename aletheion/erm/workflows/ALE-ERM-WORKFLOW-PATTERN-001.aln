}

// =============================================================================
// 5. Workflow Pattern & Examples
// =============================================================================

record WorkflowPattern {
    pattern_id                  : string
    pattern_name                : string
    description                 : string
    version                     : WorkflowVersion
    domain                      : WorkflowDomain
    status                      : WorkflowStatus
    stages                      : [WorkflowStageDefinition]
    hooks                       : [WorkflowHookDefinition]
    stage_sequence              : [StageId]
    parallel_stages             : [[StageId]]
    failure_recovery_path       : [string]
    ledger_append_points        : [StageId]
    citizen_notification_points : [StageId]
    treaty_check_points         : [StageId]
    valid_from                  : IsoTimestamp
    valid_until                 : IsoTimestamp
    schema_ref                  : string
}

// Canonical: Biodegradable Node Deployment Workflow
record Example_BiodegradeDeployment_Workflow : WorkflowPattern = {
    pattern_id                      = "WORKFLOW-BIODEGRADE-DEPLOY-001"
    pattern_name                    = "Biodegradable Node Deployment"
