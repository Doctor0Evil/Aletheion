// =============================================================================
// 16. Transaction Lifecycle & Retention
// =============================================================================

record TxLifecycle {
    lifecycle_id          : Id
    tx_id                 : TxId
    created_at            : IsoTimestamp
    validated_at          : IsoTimestamp
    appended_at           : IsoTimestamp
    last_accessed_at      : IsoTimestamp
    retention_period_days : Int
    retention_expiry      : IsoTimestamp
    archival_status       : string
    deletion_eligible     : Bool
    deletion_timestamp    : IsoTimestamp?
    deletion_authorized_by : DID?
}

record TxRetentionRule {
    rule_id               : Id
    domain                : string
    decision_outcome      : DecisionOutcome?
    treaty_violation_flag : Bool?
    retention_period_days : Int
    archival_required     : Bool
    indigenous_body_copy_required : Bool
    regulatory_body_copy_required : Bool
    public_access_after_days : Int
    deletion_conditions   : [string]
}

// =============================================================================
// 17. Audit & Compliance Records
// =============================================================================

record TxAuditRecord {
    audit_id              : Id
    tx_id                 : TxId
    audit_timestamp       : IsoTimestamp
    auditor_did           : DID
    audit_type            : string
    data_integrity_verified : Bool
    treaty_compliance_verified : Bool
    fpic_verified         : Bool
    ej_compliance_verified : Bool
    biotic_compliance_verified : Bool
    indigenous_rights_verified : Bool
    violations_found      : Int
    violations_refs       : [Id]
    remediation_required  : Bool
    remediation_deadline  : IsoTimestamp?
    audit_signature       : PQSignature
    ledger_reference      : Id
}

// =============================================================================
// 18. Cross-Transaction Linking
// =============================================================================

record TxCrossReference {
    reference_id          : Id
    source_tx_id          : TxId
    target_tx_id          : TxId
    reference_type        : string
    relationship          : string
    created_at            : IsoTimestamp
    created_by_did        : DID
}

record TxLineage {
    lineage_id            : Id
    root_tx_id            : TxId
    descendant_tx_ids     : [TxId]
    lineage_type          : string
    workflow_chain        : [WorkflowId]
    birth_sign_chain      : [Id]
    created_at            : IsoTimestamp
    updated_at            : IsoTimestamp
}

// =============================================================================
// 19. Export & Interoperability
// =============================================================================

record TxExportPackage {
    package_id            : Id
    tx_ids                : [TxId]
    export_timestamp      : IsoTimestamp
    exported_by_did       : DID
    export_format         : string
    export_purpose        : string
    recipient_did         : DID
    encryption_applied    : Bool
    access_expiry         : IsoTimestamp?
    usage_restrictions    : [string]
    treaty_compliance_attached : Bool
    ledger_reference      : Id
}

// =============================================================================
// 20. Schema Registry & Versioning
// =============================================================================

record GovernedDecisionSchemaRegistry {
    registry_id           : Id
    version               : string
    schema_ref            : Id
    valid_from            : IsoTimestamp
    valid_until           : IsoTimestamp
    total_transactions    : Int
    transactions_by_domain : [string]
    transactions_by_outcome : [string]
    compliance_rate       : Decimal
    treaty_violation_rate : Decimal
    fpic_bound_rate       : Decimal
    last_updated_at       : IsoTimestamp
    registry_signature    : PQSignature
    ledger_reference      : Id
}

// End of Aletheion Trust Schemas Governed Decision Transaction Envelope
