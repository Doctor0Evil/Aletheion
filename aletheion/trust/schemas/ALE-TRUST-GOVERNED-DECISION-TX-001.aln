// Aletheion Trust Schemas Governed Decision Transaction Envelope
// File: ALE-TRUST-GOVERNED-DECISION-TX-001.aln
// Domain: Trust / Googolswarm / Transaction Provenance
// Compliance: BioticTreaties, Indigenous FPIC, EJ Zones, SMART Chain

aln_version 1.0
namespace Aletheion.Trust.Schemas.GovernedDecision

import Aletheion.TreatyOS
import Aletheion.ERM.Ecosafety.Biodegrade
import Aletheion.Governance.Lexethos.Biodegrade

// =============================================================================
// 1. Core Transaction Identifiers
// =============================================================================

type TxId = string
type WorkflowId = string
type NodeId = string
type DID = string
type PQSignature = string
type Hash256 = string
type Hash512 = string
type IsoTimestamp = string
type Decimal = number
type Int = integer
type Bool = boolean

enum TransactionStatus {
    PENDING
    VALIDATED
    APPENDED
    REJECTED
    FLAGGED
    UNDER_REVIEW
}

enum DecisionOutcome {
    ALLOW
    BLOCK
    ALLOW_WITH_OVERRIDE
    ALLOW_WITH_DERATE
    REQUIRE_HUMAN_REVIEW
    EMERGENCY_OVERRIDE
}

enum OverrideLevel {
    NONE
    MUNICIPAL
    REGIONAL
    TREATY_JOINT_BODY
    INDIGENOUS_COUNCIL
    EMERGENCY_AUTHORITY
}

enum TreatyCheckResult {
    PASS
    FAIL
    PASS_WITH_CONDITIONS
    NOT_APPLICABLE
}

// =============================================================================
// 2. Birth-Sign & ALN Norm Bindings
// =============================================================================

record BirthSignRef {
    birth_sign_id         : Id
    tile_id               : Id
    domain                : string
    version               : Int
    valid_from            : IsoTimestamp
    valid_until           : IsoTimestamp
    constraint_bundle_ref : Id
}

record AlnNormRef {
    norm_id               : Id
    namespace             : string
    version               : Int
    norm_type             : string
    enforcement_mode      : EnforcementMode
    severity              : Severity
}

record TreatyAtomRef {
    treaty_atom_id        : Id
    treaty_type           : string
    domain                : string
    modality              : Modality
    violated              : Bool
}

// =============================================================================
// 3. Multi-Signature Attestation
// =============================================================================

record AttestorSignature {
    attestor_did          : DID
    attestor_role         : string
    signature_algorithm   : string
    pq_signature          : PQSignature
    signed_at             : IsoTimestamp
    signature_valid       : Bool
}

record MultiSigAttestation {
    attestation_id        : Id
    required_signatures   : Int
    collected_signatures  : Int
    threshold_met         : Bool
    attestors             : [AttestorSignature]
    attestation_complete  : Bool
    completed_at          : IsoTimestamp?
}

// =============================================================================
// 4. Input/Output Data Hashes (Integrity Verification)
// =============================================================================

record InputDataHash {
    input_id              : Id
    input_type            : string
    source_ref            : Id
    hash_algorithm        : string
    hash_value            : Hash512
    timestamp             : IsoTimestamp
}

record OutputDataHash {
    output_id             : Id
    output_type           : string
    destination_ref       : Id
    hash_algorithm        : string
    hash_value            : Hash512
    timestamp             : IsoTimestamp
}

record DataIntegrityProof {
    proof_id              : Id
    merkle_root           : Hash512
    input_hashes          : [InputDataHash]
    output_hashes         : [OutputDataHash]
    verification_status   : Bool
    verified_at           : IsoTimestamp
    verifier_did          : DID
}

// =============================================================================
// 5. Treaty Check Transcript
// =============================================================================

record TreatyModuleCheck {
    module_id             : Id
    module_name           : string
    check_result          : TreatyCheckResult
    violated_atoms        : [TreatyAtomRef]
    applied_norms         : [AlnNormRef]
    explanation           : string
    severity              : Severity
    timestamp             : IsoTimestamp
}

record TreatyCheckTranscript {
    transcript_id         : Id
    workflow_id           : WorkflowId
    action_id             : Id
    modules_evaluated     : [TreatyModuleCheck]
    indigenous_rights_result : TreatyCheckResult
    biotic_treaty_result     : TreatyCheckResult
    ej_zone_result           : TreatyCheckResult
    water_compact_result     : TreatyCheckResult
    neurorights_result       : TreatyCheckResult
    municipal_code_result    : TreatyCheckResult
    overall_compliance    : Bool
    violated_atom_count   : Int
    applied_norm_count    : Int
    explanation_summary   : string
    grievance_reference   : Id
    timestamp             : IsoTimestamp
}

// =============================================================================
// 6. Simulation & Optimization Summary
// =============================================================================

record SimulationOption {
    option_id             : Id
    method                : string
    energy_cost           : Decimal
    impact_score          : Decimal
    treaty_compliance_score : Decimal
    time_to_complete      : string
    selected              : Bool
}

record SimulationSummary {
    summary_id            : Id
    workflow_id           : WorkflowId
    intent                : string
    options_evaluated     : [SimulationOption]
    recommended_option    : Id
    selected_option       : Id
    optimization_criteria : [string]
    constraints_applied   : [string]
    simulation_duration_ms : Int
    timestamp             : IsoTimestamp
}

// =============================================================================
// 7. Actuation Record
// =============================================================================

record ActuationCommand {
    command_id            : Id
    actuator_id           : Id
    actuator_type         : string
    command_type          : string
    parameters            : [string]
    derate_factor         : Decimal?
    valid_until           : IsoTimestamp
    signed                : Bool
    signature_ref         : PQSignature
}

record ActuationResult {
    result_id             : Id
    command_id            : Id
    execution_status      : string
    executed_at           : IsoTimestamp
    execution_duration_ms : Int
    error_code            : string?
    error_message         : string?
    compensating_action_id : Id?
}

record ActuationRecord {
    record_id             : Id
    workflow_id           : WorkflowId
    commands              : [ActuationCommand]
    results               : [ActuationResult]
    all_successful        : Bool
    reversibility_available : Bool
    timestamp             : IsoTimestamp
}

// =============================================================================
// 8. Citizen Explanation & Notification
// =============================================================================

record CitizenExplanation {
    explanation_id        : Id
    language              : string
    title                 : string
    body                  : string
    what_happened         : string
    why_it_happened       : string
    treaties_applied      : [string]
    alternatives_rejected : [string]
    impact_summary        : string
    timestamp             : IsoTimestamp
}

record NotificationRecord {
    notification_id       : Id
    citizen_explanation_ref : Id
    notification_channels : [string]
    sent_at               : IsoTimestamp
    delivery_status       : string
    recipients_count      : Int
    grievance_link        : string
}

// =============================================================================
// 9. Grievance & Appeal Reference
// =============================================================================

record GrievanceReference {
    grievance_id          : Id
    transaction_id        : TxId
    filed_by_did          : DID?
    filed_at              : IsoTimestamp?
    status                : string
    grounds               : [string]?
    hearing_scheduled     : IsoTimestamp?
    decision              : string?
    decided_at            : IsoTimestamp?
}

record AppealRecord {
    appeal_id             : Id
    grievance_id          : Id
    transaction_id        : TxId
    filed_by_did          : DID?
    filed_at              : IsoTimestamp?
    grounds               : [string]?
    review_body_id        : Id?
    decision              : string?
    decided_at            : IsoTimestamp?
}

// =============================================================================
// 10. Energy & Resource Accounting
// =============================================================================

record EnergyAccount {
    account_id            : Id
    workflow_id           : WorkflowId
    energy_consumed_kwh   : Decimal
    energy_source         : string
    carbon_equivalent_kg  : Decimal
    renewable_fraction    : Decimal
    timestamp             : IsoTimestamp
}

record ResourceAccount {
    account_id            : Id
    workflow_id           : WorkflowId
    resource_type         : string
    resource_amount       : Decimal
    unit                  : string
    source_ref            : Id
    timestamp             : IsoTimestamp
}

// =============================================================================
// 11. Googolswarm Ledger Append Record
// =============================================================================

record LedgerAppendRecord {
    append_id             : Id
    transaction_id        : TxId
    ledger_name           : string
    block_height          : Int
    block_hash            : Hash512
    transaction_index     : Int
    appended_at           : IsoTimestamp
    confirmation_count    : Int
    finality_status       : string
    ledger_signature      : PQSignature
}

// =============================================================================
// 12. Canonical Governed Decision Transaction Envelope
// =============================================================================

record GovernedDecisionTxEnvelope {
    // Transaction Identity
    tx_id                 : TxId
    workflow_id           : WorkflowId
    envelope_version      : Int
    schema_ref            : Id
    
    // Spatial-Temporal Context
    node_id               : NodeId
    birth_sign_ids        : [Id]
    geo_tile_ref          : Id
    domain                : string
    timestamp_unix        : Int
    timestamp_iso         : IsoTimestamp
    
    // Decision Core
    decision_outcome      : DecisionOutcome
    override_level        : OverrideLevel
    override_justification : string?
    override_authorized_by : DID?
    override_approved_at  : IsoTimestamp?
    
    // Treaty & Rights Compliance
    treaty_check_transcript_ref : Id
    treaty_modules_evaluated : [Id]
    violated_atom_ids     : [Id]
    applied_norm_ids      : [Id]
    overall_compliance    : Bool
    fpic_status           : FPICStatus
    fpic_grant_ids        : [Id]
    indigenous_attestation_ref : Id?
    
    // Data Integrity
    input_data_hashes     : [InputDataHash]
    output_data_hashes    : [OutputDataHash]
    data_integrity_proof_ref : Id
    
    // Multi-Signature Attestation
    multi_sig_attestation_ref : Id
    required_attestors    : Int
    collected_attestors   : Int
    attestation_complete  : Bool
    
    // Simulation & Optimization
    simulation_summary_ref : Id
    optimization_criteria : [string]
    selected_option_id    : Id
    
    // Actuation
    actuation_record_ref  : Id
    actuation_successful  : Bool
    reversibility_available : Bool
    
    // Citizen Transparency
    citizen_explanation_ref : Id
    notification_record_ref : Id
    languages_available   : [string]
    grievance_reference   : GrievanceReference
    
    // Energy & Resource Accounting
    energy_account_ref    : Id?
    resource_accounts     : [ResourceAccount]
    
    // Ledger Append
    ledger_append_ref     : LedgerAppendRecord?
    ledger_transaction_id : Id?
    ledger_block_height   : Int?
    
    // Cryptographic Integrity
    envelope_hash         : Hash512
    pq_signature          : PQSignature
    signature_algorithm   : string
    signer_did            : DID
    signed_at             : IsoTimestamp
    
    // Status & Lifecycle
    status                : TransactionStatus
    created_at            : IsoTimestamp
    validated_at          : IsoTimestamp?
    appended_at           : IsoTimestamp?
    retention_expiry      : IsoTimestamp?
    
    // Audit & Compliance
    audit_trail_ref       : Id
    compliance_verified   : Bool
    compliance_verified_at : IsoTimestamp?
    compliance_verifier_did : DID?
}

// =============================================================================
// 13. Transaction Validation Schema
// =============================================================================

record TxValidationRule {
    rule_id               : Id
    rule_name             : string
    rule_type             : string
    required_fields       : [string]
    validation_logic      : string
    severity_on_failure   : Severity
}

record TxValidationResult {
    validation_id         : Id
    tx_id                 : TxId
    validator_did         : DID
    validated_at          : IsoTimestamp
    rules_evaluated       : [TxValidationRule]
    rules_passed          : Int
    rules_failed          : Int
    validation_passed     : Bool
    failure_details       : [string]
    validator_signature   : PQSignature
}

// =============================================================================
// 14. Transaction Query & Index Schema
// =============================================================================

record GovernedDecisionTxIndex {
    index_id              : Id
    tx_id                 : TxId
    workflow_id           : WorkflowId
    node_id               : NodeId
    domain                : string
    decision_outcome      : DecisionOutcome
    overall_compliance    : Bool
    treaty_violations     : Int
    fpic_status           : FPICStatus
    ej_zone_flag          : Bool
    indigenous_territory_flag : Bool
    biotic_corridor_flag  : Bool
    timestamp_unix        : Int
    ledger_block_height   : Int
    ledger_transaction_id : Id
    search_tags           : [string]
}

record GovernedDecisionTxQuery {
    query_id              : Id
    query_timestamp       : IsoTimestamp
    requester_did         : DID
    query_type            : string
    filters               : [string]
    tx_ids                : [TxId]?
    workflow_ids          : [WorkflowId]?
    node_ids              : [NodeId]?
    domains               : [string]?
    decision_outcomes     : [DecisionOutcome]?
    compliance_filter     : Bool?
    date_range_start      : IsoTimestamp?
    date_range_end        : IsoTimestamp?
    result_count          : Int
    result_tx_ids         : [TxId]
    query_signature       : PQSignature
}

// =============================================================================
// 15. Canonical Transaction Examples
// =============================================================================

