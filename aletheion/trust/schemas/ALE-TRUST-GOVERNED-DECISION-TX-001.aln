// Role: Canonical Googolswarm provenance schema for governed decisions in Aletheion.[file:2][file:5]
// ERM layers: L3 Blockchain Trust, L4 Optimization, L5 Citizen Interface.[file:2]
// This schema is imported by any workflow that appends governed decisions to the trust layer.

namespace ALE.TRUST.GOVERNED_DECISION_TX_001

// -----------------------------------------------------------------------------
// Core scalar aliases
// -----------------------------------------------------------------------------

atom TxId
  field value string  // Unique transaction identifier in the trust layer (e.g., Googolswarm Tx hash or UUID).[file:2]

atom WorkflowId
  field value string  // Stable workflow identifier, e.g., "WF-006-AWP-INGESTION" or "WF-022-SYNTHEXIS-LNP".[file:5]

atom WorkflowStage
  field value string  // Stage where the decision is recorded: "Optimization", "Actuation", "EmergencyOverride", etc.[file:2][file:5]

atom BirthSignId
  field value string  // Territorial governance signature identifier for a spatial tile.[file:2]

atom AlnNormId
  field value string  // Identifier of an ALN norm actually consulted in this decision (law, treaty, microtreaty clause).[file:2]

atom Did
  field value string  // Decentralized identifier for citizen, device, or institution (DID core spec compatible).[file:2]

atom NodeProfileId
  field value string  // Identifier for firmware / node profile where the decision was computed.[file:2]

atom GovernanceDomain
  field value string  // e.g., "Water", "Heat", "Mobility", "Biosignals", "Augmentation".[file:2][file:5]

atom HashReference
  field algo string    // Hash algorithm label (non-blacklisted), e.g., "GOOGOLSWARM-LEDGER-H1".[file:2]
  field value string   // Hex or base64-encoded hash value.
  field length int     // Bit-length of the hash for audit and parsing safety.

// -----------------------------------------------------------------------------
// Decision outcome and violation encoding
// -----------------------------------------------------------------------------

enum DecisionOutcome
  | Approved           // All hard constraints satisfied, no blocking FPIC issues.[file:2]
  | ApprovedWithDerating  // Soft violations present; plan derated but executed.[file:2]
  | Rejected           // Hard constraint or safety violation prevents execution.[file:2]
  | PendingFpic        // Awaiting Indigenous FPIC or equivalent territorial approval.[file:2]
  | Escalated          // Escalated to human governance or emergency override channel.[file:5]

// Severity of any violation associated with this decision.
enum ViolationSeverity
  | Info
  | Warning
  | Error
  | Critical

// Domain classification for violations.
enum ViolationDomain
  | Law
  | Indigenous
  | BioticTreaty
  | Neurorights
  | Ecosafety
  | Thermal
  | Mobility
  | Water
  | Energy
  | Materials
  | Consent
  | Other

// Individual violation record, attached to the decision envelope when constraints fail.
record Violation
  field id             string            // Local identifier for this violation instance.
  field severity       ViolationSeverity // Impact level of this violation.[file:2]
  field domain         ViolationDomain   // Domain of the violated constraint.[file:2]
  field aln_norm_id    AlnNormId?        // Optional ALN norm reference, if a specific norm was implicated.[file:2]
  field birth_sign_id  BirthSignId?      // Optional BirthSign where the violation occurred.[file:2]
  field message        string            // Machine + human readable explanation.
  field details        map<string,string>// Additional key/value context (e.g., "zone" -> "BLOCK-17").[file:2]

// -----------------------------------------------------------------------------
// Constraint evaluation summary (ALN + BirthSigns)
// -----------------------------------------------------------------------------

// Summary of governance evaluation results that led to the final outcome.[file:2][file:5]
record GovernanceEvaluation
  field constraint_mode string                 // "Hard" or "HighPenalty".[file:2]
  field satisfied       bool                   // True if all constraints satisfied or acceptable under mode.
  field hard_violations list<AlnNormId>        // ALN norms with hard violations, if any.[file:2]
  field soft_violations list<AlnNormId>        // ALN norms with soft violations, if any.[file:2]
  field fpic_status     string                 // "NotRequired" | "Granted" | "Pending" | "Denied".[file:2]
  field explanation     string                 // Short justification for governance decision.[file:2][file:5]

// -----------------------------------------------------------------------------
// Actor / node metadata
// -----------------------------------------------------------------------------

record Participants
  field subject_did  Did?           // Citizen, community, or affected subject DID (if applicable).[file:2]
  field operator_did Did?           // Operator, planner, or system DID submitting this decision.[file:2]
  field node_profile NodeProfileId? // Node profile on which the decision was computed.[file:2]
  field domains      list<GovernanceDomain> // Domains influenced by this decision (e.g., ["Water","Heat"]).[file:2][file:5]

// -----------------------------------------------------------------------------
// Temporal metadata
// -----------------------------------------------------------------------------

record TimeWindow
  field decision_at       datetime   // Timestamp at which the decision was finalized.[file:2]
  field action_effective_at datetime? // Planned time when actuation becomes effective, if different.[file:5]
  field window_start      datetime?  // Optional start of the controlled window.
  field window_end        datetime?  // Optional end of the controlled window.

// -----------------------------------------------------------------------------
// Core governed decision transaction schema
// -----------------------------------------------------------------------------

record GovernedDecisionTx
  // Core identifiers
  field tx_id           TxId
  field workflow_id     WorkflowId
  field workflow_stage  WorkflowStage

  // Territorial context
  field birth_sign_ids  list<BirthSignId> // All BirthSigns applied during evaluation.[file:2]
  field primary_birth_sign BirthSignId?   // Optional primary or dominant BirthSign for this decision.[file:2]

  // Governance norms actually consulted
  field applied_aln_norms      list<AlnNormId> // Explicit ALN norms evaluated (laws, treaties, overlays).[file:2]
  field applied_biotic_treaties list<AlnNormId> // BioticTreaty norms used in evaluation.[file:2]
  field applied_micro_treaties list<AlnNormId> // LexEthos microtreaty norms used in evaluation.[file:2]

  // Actors and node context
  field participants    Participants

  // Input / output references for replay and audit
  field inputs_hash     HashReference   // Hash over canonicalized inputs to the decision.[file:2]
  field outputs_hash    HashReference   // Hash over canonicalized outputs (plan or actuation set).[file:2]

  // Governance evaluation + outcome
  field evaluation      GovernanceEvaluation
  field outcome         DecisionOutcome
  field violations      list<Violation> // Possibly empty if fully satisfied.[file:2]

  // Time metadata
  field time_window     TimeWindow

  // Free-form tags for domain-specific telemetry (must not redefine governance meaning).
  field tags            map<string,string>

// -----------------------------------------------------------------------------
// Constraints and validation rules (schema-level intents)
// -----------------------------------------------------------------------------

rule require_primary_birthsign_when_single
  when tx: GovernedDecisionTx
  if size(tx.birth_sign_ids) == 1
  then tx.primary_birth_sign != null

rule require_inputs_outputs_hash
  when tx: GovernedDecisionTx
  then tx.inputs_hash.value  != ""
   and tx.outputs_hash.value != ""

rule require_outcome_consistency
  when tx: GovernedDecisionTx
  then
    case tx.outcome of
      | Approved ->
          tx.evaluation.satisfied == true
          and size(tx.evaluation.hard_violations) == 0
          and tx.evaluation.fpic_status != "Denied"
          and tx.evaluation.fpic_status != "Pending"
      | ApprovedWithDerating ->
          size(tx.evaluation.soft_violations) > 0
          and tx.evaluation.constraint_mode == "HighPenalty"
      | Rejected ->
          size(tx.evaluation.hard_violations) > 0
          or tx.evaluation.fpic_status == "Denied"
      | PendingFpic ->
          tx.evaluation.fpic_status == "Pending"
      | Escalated ->
          true
    end

rule require_birthsign_for_governed_decision
  when tx: GovernedDecisionTx
  then size(tx.birth_sign_ids) > 0

// End of ALE-TRUST-GOVERNED-DECISION-TX-001.aln
