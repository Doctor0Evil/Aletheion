// =============================================================================
// 16. Shard Validation Contracts
// =============================================================================

record ShardValidationContract {
    validator_id            : string
    description             : string
    accepts_shard_types     : [string]
    required_fields         : [string]
    optional_fields         : [string]
    treaty_checks_required  : [string]
    signature_verification  : Bool
    multi_sig_threshold     : Int
    indigenous_attestation_required_for : [string]
    fpic_required_for       : [string]
    ej_enhanced_review_for  : [string]
}

record ShardValidationResult {
    validation_id           : string
    shard_id                : ShardId
    validator_id            : string
    timestamp               : IsoTimestamp
    validation_passed       : Bool
    required_fields_present : Bool
    treaty_checks_passed    : Bool
    signature_verified      : Bool
    multi_sig_threshold_met : Bool
    violations_found        : [string]
    warnings                : [string]
    validator_signature     : PQSignature
    ledger_reference        : string
}

// =============================================================================
// 17. Data Quality & Integrity Records
// =============================================================================

record DataQualityScore {
    score_id                : string
    shard_id                : ShardId
    timestamp               : IsoTimestamp
    completeness_score      : Decimal
    accuracy_score          : Decimal
    consistency_score       : Decimal
    timeliness_score        : Decimal
    validity_score          : Decimal
    overall_quality_score   : Decimal
    quality_tier            : string
    assessor_did            : DID
}

record DataIntegrityProof {
    proof_id                : string
    shard_id                : ShardId
    timestamp               : IsoTimestamp
    merkle_root             : string
    data_hash               : string
    signature_algorithm     : string
    pq_signature            : PQSignature
    verifier_did            : DID
    verification_timestamp  : IsoTimestamp
    ledger_reference        : string
}

// =============================================================================
// 18. Cross-Shard Linking & References
// =============================================================================

record ShardCrossReference {
    reference_id            : string
    source_shard_id         : ShardId
    target_shard_id         : ShardId
    reference_type          : string
    relationship            : string
    created_timestamp       : IsoTimestamp
    created_by_did          : DID
    ledger_reference        : string
}

record ShardLineage {
    lineage_id              : string
    root_shard_id           : ShardId
    descendant_shard_ids    : [ShardId]
    lineage_type            : string
    experiment_chain        : [string]
    material_chain          : [string]
    corridor_chain          : [string]
    birth_sign_chain        : [BirthSignId]
    created_timestamp       : IsoTimestamp
    updated_timestamp       : IsoTimestamp
}

// =============================================================================
// 19. Export & Interoperability Schemas
// =============================================================================

record ShardExportPackage {
    package_id              : string
    shard_ids               : [ShardId]
    export_timestamp        : IsoTimestamp
    exported_by_did         : DID
    export_format           : string
    export_purpose          : string
    recipient_did           : DID
    encryption_applied      : Bool
    access_expiry           : IsoTimestamp?
    usage_restrictions      : [string]
    treaty_compliance_attached : Bool
    ledger_reference        : string
}

record InteroperabilityMapping {
    mapping_id              : string
    aletheion_schema_ref    : string
    external_schema_name    : string
    external_schema_version : string
    field_mappings          : [string]
    transformation_rules    : [string]
    lossless_conversion     : Bool
    treaty_preservation     : Bool
    created_timestamp       : IsoTimestamp
    created_by_did          : DID
}

// =============================================================================
// 20. Shard Registry & Discovery
// =============================================================================

record BiodegradeShardRegistry {
    registry_id             : string
    version                 : string
    total_shards            : Int
    shards_by_type          : [string]
    shards_by_status        : [string]
    shards_by_risk_level    : [string]
    shards_by_experiment_type : [string]
    treaty_compliant_shards : Int
    fpic_bound_shards       : Int
    indigenous_accessible_shards : Int
    ej_zone_shards          : Int
    biotic_corridor_shards  : Int
    last_updated_timestamp  : IsoTimestamp
    registry_signature      : PQSignature
    ledger_reference        : string
}

record ShardDiscoveryIndex {
    index_id                : string
    shard_id                : ShardId
    searchable_fields       : [string]
    geo_hash                : GeoHash
    birth_sign_id           : BirthSignId
    corridor_id             : CorridorId
    experiment_type         : ExperimentType
    status                  : ShardStatus
    risk_level              : LeachateRiskLevel
    treaty_compliant        : Bool
    created_timestamp       : IsoTimestamp
    appended_timestamp      : IsoTimestamp
    ledger_transaction_id   : string
}

// End of Aletheion Trust Schemas Biodegrade QPU Data Shard
